<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- SPACING -->
    <Thickness x:Key="Spacing.XS">4</Thickness>
    <Thickness x:Key="Spacing.S">8</Thickness>
    <Thickness x:Key="Spacing.M">12</Thickness>
    <Thickness x:Key="Spacing.L">16</Thickness>
    <Thickness x:Key="Spacing.XL">24</Thickness>
    <Thickness x:Key="Spacing.XXL">32</Thickness>

    <!-- COMMON PADDINGS -->
    <Thickness x:Key="Padding.Control">12,8</Thickness>
    <Thickness x:Key="Padding.ControlDense">10,6</Thickness>
    <Thickness x:Key="Padding.Card">16</Thickness>
    <Thickness x:Key="Padding.Window">24</Thickness>

    <!-- COMMON MARGINS -->
    <Thickness x:Key="Margin.Section">0,0,0,24</Thickness>
    <Thickness x:Key="Margin.Control">0,0,0,12</Thickness>
</ResourceDictionary>