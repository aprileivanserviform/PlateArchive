<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dipendenze: le Color.* devono essere nello stesso scope per StaticResource -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/PlateArchive.Ui;component/Themes/Colors/LightColors.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- ═══════════════════════════════════════
         BRAND / PRIMARY
    ═══════════════════════════════════════ -->
    <SolidColorBrush x:Key="Brush.Primary"         Color="{StaticResource Color.Primary}" />
    <SolidColorBrush x:Key="Brush.PrimaryHover"    Color="{StaticResource Color.PrimaryHover}" />
    <SolidColorBrush x:Key="Brush.PrimaryPressed"  Color="{StaticResource Color.PrimaryPressed}" />
    <SolidColorBrush x:Key="Brush.PrimaryLight"    Color="{StaticResource Color.PrimaryLight}" />
    <SolidColorBrush x:Key="Brush.PrimaryLighter"  Color="{StaticResource Color.PrimaryLighter}" />
    <SolidColorBrush x:Key="Brush.OnPrimary"       Color="{StaticResource Color.OnPrimary}" />

    <!-- ═══════════════════════════════════════
         BACKGROUND / SURFACES
    ═══════════════════════════════════════ -->
    <SolidColorBrush x:Key="Brush.Background"      Color="{StaticResource Color.Background}" />
    <SolidColorBrush x:Key="Brush.Surface"         Color="{StaticResource Color.Surface}" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt"      Color="{StaticResource Color.SurfaceAlt}" />
    <SolidColorBrush x:Key="Brush.SurfaceVariant"  Color="{StaticResource Color.SurfaceVariant}" />
    <SolidColorBrush x:Key="Brush.SurfaceHover"    Color="{StaticResource Color.SurfaceHover}" />

    <!-- ═══════════════════════════════════════
         BORDERS
    ═══════════════════════════════════════ -->
    <SolidColorBrush x:Key="Brush.Border"          Color="{StaticResource Color.Border}" />
    <SolidColorBrush x:Key="Brush.BorderStrong"    Color="{StaticResource Color.BorderStrong}" />

    <!-- ═══════════════════════════════════════
         TEXT
    ═══════════════════════════════════════ -->
    <SolidColorBrush x:Key="Brush.TextPrimary"     Color="{StaticResource Color.TextPrimary}" />
    <SolidColorBrush x:Key="Brush.TextSecondary"   Color="{StaticResource Color.TextSecondary}" />
    <SolidColorBrush x:Key="Brush.TextDisabled"    Color="{StaticResource Color.TextDisabled}" />

    <!-- ═══════════════════════════════════════
         STATUS / SEMANTIC
    ═══════════════════════════════════════ -->
    <SolidColorBrush x:Key="Brush.Success"             Color="{StaticResource Color.Success}" />
    <SolidColorBrush x:Key="Brush.SuccessSurface"      Color="{StaticResource Color.SuccessSurface}" />
    <SolidColorBrush x:Key="Brush.Warning"             Color="{StaticResource Color.Warning}" />
    <SolidColorBrush x:Key="Brush.WarningSurface"      Color="{StaticResource Color.WarningSurface}" />
    <SolidColorBrush x:Key="Brush.Error"               Color="{StaticResource Color.Error}" />
    <SolidColorBrush x:Key="Brush.ErrorSurface"        Color="{StaticResource Color.ErrorSurface}" />
    <SolidColorBrush x:Key="Brush.Info"                Color="{StaticResource Color.Info}" />
    <SolidColorBrush x:Key="Brush.InfoSurface"         Color="{StaticResource Color.InfoSurface}" />

    <!-- ═══════════════════════════════════════
         UI STATES
    ═══════════════════════════════════════ -->
    <SolidColorBrush x:Key="Brush.Focus"           Color="{StaticResource Color.Focus}" />
    <SolidColorBrush x:Key="Brush.Selection"       Color="{StaticResource Color.Selection}" />
    <SolidColorBrush x:Key="Brush.Overlay"         Color="{StaticResource Color.Overlay}" />

    <!-- ═══════════════════════════════════════
         CONTROL STATES
    ═══════════════════════════════════════ -->
    <SolidColorBrush x:Key="Brush.ControlBackground"  Color="{StaticResource Color.ControlBackground}" />
    <SolidColorBrush x:Key="Brush.ControlHover"       Color="{StaticResource Color.ControlHover}" />
    <SolidColorBrush x:Key="Brush.ControlPressed"     Color="{StaticResource Color.ControlPressed}" />

    <!-- ═══════════════════════════════════════
         INPUTS
    ═══════════════════════════════════════ -->
    <SolidColorBrush x:Key="Brush.InputBackground"         Color="{StaticResource Color.InputBackground}" />
    <SolidColorBrush x:Key="Brush.InputReadOnlyBackground" Color="{StaticResource Color.InputReadOnlyBackground}" />
    <SolidColorBrush x:Key="Brush.InputForeground"         Color="{StaticResource Color.TextPrimary}" />
    <SolidColorBrush x:Key="Brush.InputBorder"             Color="{StaticResource Color.Border}" />
    <SolidColorBrush x:Key="Brush.InputBorderFocus"        Color="{StaticResource Color.Focus}" />
    <SolidColorBrush x:Key="Brush.InputBorderError"        Color="{StaticResource Color.Error}" />

    <!-- ═══════════════════════════════════════
         BUTTON
    ═══════════════════════════════════════ -->
    <SolidColorBrush x:Key="Brush.ButtonPrimaryBackground"        Color="{StaticResource Color.Primary}" />
    <SolidColorBrush x:Key="Brush.ButtonPrimaryBackgroundHover"   Color="{StaticResource Color.PrimaryHover}" />
    <SolidColorBrush x:Key="Brush.ButtonPrimaryBackgroundPressed" Color="{StaticResource Color.PrimaryPressed}" />
    <SolidColorBrush x:Key="Brush.ButtonPrimaryForeground"        Color="{StaticResource Color.OnPrimary}" />

    <!-- ═══════════════════════════════════════
         DROPDOWN / LIST
    ═══════════════════════════════════════ -->
    <SolidColorBrush x:Key="Brush.ItemHover"       Color="{StaticResource Color.ItemHover}" />
    <SolidColorBrush x:Key="Brush.ItemSelected"    Color="{StaticResource Color.ItemSelected}" />
    <SolidColorBrush x:Key="Brush.PopupBackground" Color="{StaticResource Color.PopupBackground}" />

    <!-- ═══════════════════════════════════════
         CHECKBOX / TOGGLE
    ═══════════════════════════════════════ -->
    <SolidColorBrush x:Key="Brush.CheckMark"       Color="{StaticResource Color.CheckMark}" />

</ResourceDictionary>
