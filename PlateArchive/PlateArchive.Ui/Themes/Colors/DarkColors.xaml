<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════
         BRAND
    ═══════════════════════════════════════ -->
    <Color x:Key="Color.Primary">#A475F9</Color>
    <Color x:Key="Color.PrimaryHover">#B38AFF</Color>
    <Color x:Key="Color.PrimaryPressed">#8C5BE8</Color>
    <Color x:Key="Color.PrimaryLight">#C7AEFF</Color>
    <Color x:Key="Color.PrimaryLighter">#2F2545</Color>

    <!-- ═══════════════════════════════════════
         BACKGROUND / SURFACES
         Background  → sfondo applicazione (livello base)
         Surface     → card, pannelli, topbar (livello 1)
         SurfaceAlt  → alternativa piatta a Surface, stesso livello visivo
         SurfaceVariant → superficie più elevata: card dentro card,
                          tooltip, popover, pannelli secondari (livello 2)
         SurfaceHover → stato hover su superfici cliccabili
    ═══════════════════════════════════════ -->
    <Color x:Key="Color.Background">#1E1E1E</Color>
    <Color x:Key="Color.Surface">#252526</Color>
    <Color x:Key="Color.SurfaceAlt">#2D2D30</Color>
    <Color x:Key="Color.SurfaceVariant">#323236</Color>
    <Color x:Key="Color.SurfaceHover">#333337</Color>

    <!-- ═══════════════════════════════════════
         BORDERS
    ═══════════════════════════════════════ -->
    <Color x:Key="Color.Border">#3F3F46</Color>
    <Color x:Key="Color.BorderStrong">#5A5A66</Color>

    <!-- ═══════════════════════════════════════
         TEXT
    ═══════════════════════════════════════ -->
    <Color x:Key="Color.TextPrimary">#F3F3F3</Color>
    <Color x:Key="Color.TextSecondary">#C8C8C8</Color>
    <Color x:Key="Color.TextDisabled">#8A8A8F</Color>
    <Color x:Key="Color.OnPrimary">#FFFFFF</Color>

    <!-- ═══════════════════════════════════════
         STATUS — colore puro + surface tenue per background
         Il Surface è pensato per banner, toast, campi di input
         con validation error, ecc. (colore a ~15% opacity su Background)
    ═══════════════════════════════════════ -->
    <Color x:Key="Color.Success">#4EC98A</Color>
    <Color x:Key="Color.SuccessSurface">#1A3529</Color>
    <Color x:Key="Color.Warning">#F0B44C</Color>
    <Color x:Key="Color.WarningSurface">#382B14</Color>
    <Color x:Key="Color.Error">#F06A7B</Color>
    <Color x:Key="Color.ErrorSurface">#3A1820</Color>
    <Color x:Key="Color.Info">#7AA6FF</Color>
    <Color x:Key="Color.InfoSurface">#1A2540</Color>

    <!-- ═══════════════════════════════════════
         UI STATES
    ═══════════════════════════════════════ -->
    <Color x:Key="Color.Focus">#B08BFF</Color>
    <Color x:Key="Color.Selection">#3A2D57</Color>
    <Color x:Key="Color.Overlay">#99000000</Color>

    <!-- ═══════════════════════════════════════
         CONTROL STATES
    ═══════════════════════════════════════ -->
    <Color x:Key="Color.ControlBackground">#2D2D30</Color>
    <Color x:Key="Color.ControlHover">#37373D</Color>
    <Color x:Key="Color.ControlPressed">#41414A</Color>

    <!-- ═══════════════════════════════════════
         INPUTS
    ═══════════════════════════════════════ -->
    <Color x:Key="Color.InputBackground">#1F1F22</Color>
    <Color x:Key="Color.InputReadOnlyBackground">#2A2A2E</Color>

    <!-- ═══════════════════════════════════════
         DROPDOWN / LIST
    ═══════════════════════════════════════ -->
    <Color x:Key="Color.ItemHover">#37373D</Color>
    <Color x:Key="Color.ItemSelected">#3A2D57</Color>
    <Color x:Key="Color.PopupBackground">#252526</Color>

    <!-- ═══════════════════════════════════════
         CHECKBOX / TOGGLE
    ═══════════════════════════════════════ -->
    <Color x:Key="Color.CheckMark">#FFFFFF</Color>

</ResourceDictionary>
