<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════
         BRAND
    ═══════════════════════════════════════ -->
    <Color x:Key="Color.Primary">#8B5FD3</Color>
    <Color x:Key="Color.PrimaryHover">#7C4FC4</Color>
    <Color x:Key="Color.PrimaryPressed">#693DAF</Color>
    <Color x:Key="Color.PrimaryLight">#B89AE6</Color>
    <Color x:Key="Color.PrimaryLighter">#F1EBFB</Color>

    <!-- ═══════════════════════════════════════
         BACKGROUND / SURFACES
    ═══════════════════════════════════════ -->
    <Color x:Key="Color.Background">#F7F8FC</Color>
    <Color x:Key="Color.Surface">#FFFFFF</Color>
    <Color x:Key="Color.SurfaceAlt">#F3F0F8</Color>
    <Color x:Key="Color.SurfaceVariant">#EDE8F5</Color>
    <Color x:Key="Color.SurfaceHover">#ECE7F5</Color>

    <!-- ═══════════════════════════════════════
         BORDERS
    ═══════════════════════════════════════ -->
    <Color x:Key="Color.Border">#DDD4EC</Color>
    <Color x:Key="Color.BorderStrong">#BCA9DD</Color>

    <!-- ═══════════════════════════════════════
         TEXT
    ═══════════════════════════════════════ -->
    <Color x:Key="Color.TextPrimary">#1F1B24</Color>
    <Color x:Key="Color.TextSecondary">#5F5968</Color>
    <Color x:Key="Color.TextDisabled">#9C95A8</Color>
    <Color x:Key="Color.OnPrimary">#FFFFFF</Color>

    <!-- ═══════════════════════════════════════
         STATUS
    ═══════════════════════════════════════ -->
    <Color x:Key="Color.Success">#2EAE6B</Color>
    <Color x:Key="Color.SuccessSurface">#E8F8F0</Color>
    <Color x:Key="Color.Warning">#D9911A</Color>
    <Color x:Key="Color.WarningSurface">#FDF3E3</Color>
    <Color x:Key="Color.Error">#D94B5A</Color>
    <Color x:Key="Color.ErrorSurface">#FDEDEF</Color>
    <Color x:Key="Color.Info">#5C7CFA</Color>
    <Color x:Key="Color.InfoSurface">#EEF2FF</Color>

    <!-- ═══════════════════════════════════════
         UI STATES
    ═══════════════════════════════════════ -->
    <Color x:Key="Color.Focus">#A780E8</Color>
    <Color x:Key="Color.Selection">#E8DDFC</Color>
    <Color x:Key="Color.Overlay">#80000000</Color>

    <!-- ═══════════════════════════════════════
         CONTROL STATES
    ═══════════════════════════════════════ -->
    <Color x:Key="Color.ControlBackground">#FFFFFF</Color>
    <Color x:Key="Color.ControlHover">#F3F0F8</Color>
    <Color x:Key="Color.ControlPressed">#E8DDFC</Color>

    <!-- ═══════════════════════════════════════
         INPUTS
    ═══════════════════════════════════════ -->
    <Color x:Key="Color.InputBackground">#FFFFFF</Color>
    <Color x:Key="Color.InputReadOnlyBackground">#F3F0F8</Color>

    <!-- ═══════════════════════════════════════
         DROPDOWN / LIST
    ═══════════════════════════════════════ -->
    <Color x:Key="Color.ItemHover">#F3F0F8</Color>
    <Color x:Key="Color.ItemSelected">#E8DDFC</Color>
    <Color x:Key="Color.PopupBackground">#FFFFFF</Color>

    <!-- ═══════════════════════════════════════
         CHECKBOX / TOGGLE
    ═══════════════════════════════════════ -->
    <Color x:Key="Color.CheckMark">#FFFFFF</Color>

</ResourceDictionary>
