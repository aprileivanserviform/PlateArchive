<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Stili applicativi generici PlateArchive
        ════════════════════════════════════════
        Self-contained: include le proprie dipendenze.
    -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/PlateArchive.Ui;component/Themes/Base/Spacing.xaml"/>
        <ResourceDictionary Source="/PlateArchive.Ui;component/Themes/Base/CornerRadius.xaml"/>
        <ResourceDictionary Source="/PlateArchive.Ui;component/Themes/Base/Typography.xaml"/>
        <ResourceDictionary Source="/PlateArchive.Ui;component/Themes/Base/Elevation.xaml"/>
        <ResourceDictionary Source="/PlateArchive.Ui;component/Themes/Brushes/LightBrushes.xaml"/>
        <ResourceDictionary Source="/PlateArchive.Ui;component/Themes/Styles/ButtonStyles.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- ── Rendering pixel-perfect globale ────────────────────── -->
    <Style TargetType="{x:Type FrameworkElement}">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding"   Value="True"/>
    </Style>
    <Style TargetType="{x:Type Control}">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding"   Value="True"/>
    </Style>

    <!-- ── Convertitori globali ────────────────────────────────── -->
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>

    <!-- ── Bottone variante Danger ─────────────────────────────── -->
    <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource Button.Secondary}">
        <Setter Property="Foreground"  Value="{DynamicResource Brush.Error}"/>
        <Setter Property="Background"  Value="{DynamicResource Brush.ErrorSurface}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Error}"/>
    </Style>

    <!-- ── Bottoni alias (retrocompatibilità) ─────────────────── -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource Button.Primary}"/>
    <Style x:Key="SmallButtonStyle"   TargetType="Button" BasedOn="{StaticResource Button.Secondary}"/>
    <Style x:Key="PrimaryBtn"         TargetType="Button" BasedOn="{StaticResource Button.Primary}"/>
    <Style x:Key="SecondaryBtn"       TargetType="Button" BasedOn="{StaticResource Button.Secondary}"/>
    <Style x:Key="ActionButtonStyle"  TargetType="Button" BasedOn="{StaticResource Button.Primary}"/>
    <Style x:Key="SearchButtonStyle"  TargetType="Button" BasedOn="{StaticResource Button.Secondary}"/>

    <!-- ── Form fields ─────────────────────────────────────────── -->
    <Style x:Key="FieldLabel" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="{StaticResource FontSize.Caption}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
        <Setter Property="Margin"     Value="0,0,0,3"/>
    </Style>
    <Style x:Key="FieldBox" TargetType="TextBox">
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>

    <!-- ── Layout etichette (ex LabelStyle / ValueStyle) ─────── -->
    <Style x:Key="LabelStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
        <Setter Property="FontSize"   Value="{StaticResource FontSize.Caption}"/>
        <Setter Property="Margin"     Value="0,0,0,2"/>
    </Style>
    <Style x:Key="ValueStyle" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="{StaticResource FontSize.BodyLarge}"/>
        <Setter Property="Margin"     Value="0,0,0,14"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
    </Style>

    <!-- ── Titolo sezione pannello dettaglio ───────────────────── -->
    <Style x:Key="SectionTitle" TargetType="TextBlock">
        <Setter Property="FontWeight" Value="{StaticResource FontWeight.SemiBold}"/>
        <Setter Property="FontSize"   Value="{StaticResource FontSize.Caption}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
        <Setter Property="Margin"     Value="0,0,0,6"/>
    </Style>

</ResourceDictionary>
