<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dipendenze self-contained: token Base necessari per {StaticResource ...} -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/PlateArchive.Ui;component/Themes/Base/Spacing.xaml"/>
        <ResourceDictionary Source="/PlateArchive.Ui;component/Themes/Base/CornerRadius.xaml"/>
        <ResourceDictionary Source="/PlateArchive.Ui;component/Themes/Base/Typography.xaml"/>
        <ResourceDictionary Source="/PlateArchive.Ui;component/Themes/Base/Elevation.xaml"/>
    </ResourceDictionary.MergedDictionaries>


    <!-- ─────────────────────────────────────────
         NAV ITEM — versione base (testo semplice)
         Uguale al ListBoxItem.Navigation esistente,
         ma qui centralizzato con semantica propria
    ───────────────────────────────────────── -->
    <Style x:Key="NavItem.Base" TargetType="ListBoxItem">
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="Margin" Value="0,0,0,4" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontFamily" Value="{StaticResource FontFamily.Base}" />
        <Setter Property="FontSize" Value="{StaticResource FontSize.Body}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource Radius.M}"
                            Padding="{TemplateBinding Padding}">
                        <!-- Accent bar sinistra, visibile solo su selected -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="AccentBar"
                                    Grid.Column="0"
                                    Width="3"
                                    CornerRadius="2"
                                    Background="{DynamicResource Brush.Primary}"
                                    Visibility="Collapsed"
                                    Margin="0,4"/>
                            <ContentPresenter Grid.Column="1"
                                              Margin="8,0,0,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Stretch"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.ItemHover}" />
                            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.ItemSelected}" />
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.Primary}" />
                            <Setter TargetName="AccentBar" Property="Visibility" Value="Visible" />
                            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
                            <Setter Property="FontWeight" Value="{StaticResource FontWeight.SemiBold}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ─────────────────────────────────────────
         NAV SECTION HEADER
         Label non cliccabile per separare gruppi
         Es: "MODULI", "IMPOSTAZIONI"
    ───────────────────────────────────────── -->
    <Style x:Key="NavSection.Header" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontFamily.Base}" />
        <Setter Property="FontSize" Value="{StaticResource FontSize.Caption}" />
        <Setter Property="FontWeight" Value="{StaticResource FontWeight.SemiBold}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextDisabled}" />
        <Setter Property="Margin" Value="14,12,0,4" />
        <Setter Property="TextWrapping" Value="NoWrap" />
    </Style>

    <!-- ─────────────────────────────────────────
         NAV CONTAINER (ListBox che ospita i NavItem)
    ───────────────────────────────────────── -->
    <Style x:Key="NavList.Base" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="KeyboardNavigation.DirectionalNavigation" Value="Cycle" />
    </Style>

</ResourceDictionary>