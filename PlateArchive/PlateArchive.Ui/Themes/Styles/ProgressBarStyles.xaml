<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dipendenze self-contained: token Base necessari per {StaticResource ...} -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/PlateArchive.Ui;component/Themes/Base/Spacing.xaml"/>
        <ResourceDictionary Source="/PlateArchive.Ui;component/Themes/Base/CornerRadius.xaml"/>
        <ResourceDictionary Source="/PlateArchive.Ui;component/Themes/Base/Typography.xaml"/>
        <ResourceDictionary Source="/PlateArchive.Ui;component/Themes/Base/Elevation.xaml"/>
    </ResourceDictionary.MergedDictionaries>


    <Style x:Key="ProgressBar.Base" TargetType="ProgressBar">
        <Setter Property="Height"              Value="6"/>
        <Setter Property="Background"          Value="{DynamicResource Brush.SurfaceVariant}"/>
        <Setter Property="Foreground"          Value="{DynamicResource Brush.Primary}"/>
        <Setter Property="BorderThickness"     Value="0"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding"   Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Grid x:Name="Root" SnapsToDevicePixels="True">

                        <!-- Track: sfondo della barra -->
                        <Border x:Name="PART_Track"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"/>

                        <!-- Indicator: riempimento — WPF ne gestisce la larghezza automaticamente -->
                        <Border x:Name="PART_Indicator"
                                HorizontalAlignment="Left"
                                Background="{TemplateBinding Foreground}"
                                CornerRadius="3"/>

                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ProgressBar.Thin"
           TargetType="ProgressBar"
           BasedOn="{StaticResource ProgressBar.Base}">
        <Setter Property="Height" Value="4"/>
    </Style>

    <Style x:Key="ProgressBar.Thick"
           TargetType="ProgressBar"
           BasedOn="{StaticResource ProgressBar.Base}">
        <Setter Property="Height" Value="10"/>
    </Style>

    <Style x:Key="ProgressBar.Success"
           TargetType="ProgressBar"
           BasedOn="{StaticResource ProgressBar.Base}">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Success}"/>
    </Style>

    <Style x:Key="ProgressBar.Warning"
           TargetType="ProgressBar"
           BasedOn="{StaticResource ProgressBar.Base}">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Warning}"/>
    </Style>

    <Style x:Key="ProgressBar.Error"
           TargetType="ProgressBar"
           BasedOn="{StaticResource ProgressBar.Base}">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Error}"/>
    </Style>

    <Style TargetType="ProgressBar" BasedOn="{StaticResource ProgressBar.Base}"/>

</ResourceDictionary>
