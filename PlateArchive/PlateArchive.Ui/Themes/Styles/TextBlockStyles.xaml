<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dipendenze self-contained: token Base necessari per {StaticResource ...} -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/PlateArchive.Ui;component/Themes/Base/Spacing.xaml"/>
        <ResourceDictionary Source="/PlateArchive.Ui;component/Themes/Base/CornerRadius.xaml"/>
        <ResourceDictionary Source="/PlateArchive.Ui;component/Themes/Base/Typography.xaml"/>
        <ResourceDictionary Source="/PlateArchive.Ui;component/Themes/Base/Elevation.xaml"/>
    </ResourceDictionary.MergedDictionaries>


    <!--
        NOTA RENDERING TESTO
        ─────────────────────────────────────────────────────────────────
        TextFormattingMode="Ideal" viene impostato QUI su ogni stile
        esplicito, perché la proprietà TextOptions NON si eredita tramite
        BasedOn né tramite lo stile implicito di Window.
        Su testi piccoli/medi "Ideal" + ClearType dà il risultato più
        nitido su display standard e HiDPI PerMonitorV2.
        "Display" andava bene fino a WPF 3.5 a 96dpi fisso; su monitor
        moderni sgrana (pixel-grid mismatch a DPI frazioni).
    -->

    <!-- BASE TEXT -->
    <Style x:Key="TextBlock.Base" TargetType="TextBlock">
        <Setter Property="FontFamily"                         Value="{StaticResource FontFamily.Base}"/>
        <Setter Property="Foreground"                         Value="{DynamicResource Brush.TextPrimary}"/>
        <Setter Property="TextWrapping"                       Value="Wrap"/>
        <Setter Property="TextOptions.TextFormattingMode"     Value="Ideal"/>
        <Setter Property="TextOptions.TextRenderingMode"      Value="ClearType"/>
        <Setter Property="RenderOptions.ClearTypeHint"        Value="Enabled"/>
        <Setter Property="UseLayoutRounding"                  Value="True"/>
        <Setter Property="SnapsToDevicePixels"                Value="True"/>
    </Style>

    <!-- HEADLINE -->
    <Style x:Key="TextBlock.Headline"
           TargetType="TextBlock"
           BasedOn="{StaticResource TextBlock.Base}">
        <Setter Property="FontSize"   Value="{StaticResource FontSize.Headline}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- TITLE -->
    <Style x:Key="TextBlock.Title"
           TargetType="TextBlock"
           BasedOn="{StaticResource TextBlock.Base}">
        <Setter Property="FontSize"   Value="{StaticResource FontSize.Title}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- SUBTITLE -->
    <Style x:Key="TextBlock.Subtitle"
           TargetType="TextBlock"
           BasedOn="{StaticResource TextBlock.Base}">
        <Setter Property="FontSize"   Value="{StaticResource FontSize.Subtitle}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
    </Style>

    <!-- BODY -->
    <Style x:Key="TextBlock.Body"
           TargetType="TextBlock"
           BasedOn="{StaticResource TextBlock.Base}">
        <Setter Property="FontSize"   Value="{StaticResource FontSize.Body}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
    </Style>

    <!-- BODY LARGE -->
    <Style x:Key="TextBlock.BodyLarge"
           TargetType="TextBlock"
           BasedOn="{StaticResource TextBlock.Base}">
        <Setter Property="FontSize" Value="{StaticResource FontSize.BodyLarge}"/>
    </Style>

    <!-- CAPTION -->
    <Style x:Key="TextBlock.Caption"
           TargetType="TextBlock"
           BasedOn="{StaticResource TextBlock.Base}">
        <Setter Property="FontSize"   Value="{StaticResource FontSize.Caption}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
        <Setter Property="Opacity"    Value="0.8"/>
    </Style>

    <!-- Stile implicito — applica le proprietà di rendering a tutti i TextBlock -->
    <Style TargetType="TextBlock" BasedOn="{StaticResource TextBlock.Base}"/>

</ResourceDictionary>
