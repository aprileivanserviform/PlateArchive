<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dipendenze self-contained: token Base necessari per {StaticResource ...} -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/PlateArchive.Ui;component/Themes/Base/Spacing.xaml"/>
        <ResourceDictionary Source="/PlateArchive.Ui;component/Themes/Base/CornerRadius.xaml"/>
        <ResourceDictionary Source="/PlateArchive.Ui;component/Themes/Base/Typography.xaml"/>
        <ResourceDictionary Source="/PlateArchive.Ui;component/Themes/Base/Elevation.xaml"/>
    </ResourceDictionary.MergedDictionaries>


    <Style x:Key="Window.Base" TargetType="Window">
        <Setter Property="Background"          Value="{DynamicResource Brush.Background}"/>
        <Setter Property="Foreground"          Value="{DynamicResource Brush.TextPrimary}"/>
        <Setter Property="FontFamily"          Value="{StaticResource FontFamily.Base}"/>
        <Setter Property="FontSize"            Value="{StaticResource FontSize.Body}"/>
        <Setter Property="UseLayoutRounding"   Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
        <Setter Property="TextOptions.TextRenderingMode"  Value="ClearType"/>
        <Setter Property="RenderOptions.ClearTypeHint"    Value="Enabled"/>
        <Setter Property="WindowStyle"         Value="SingleBorderWindow"/>
        <Setter Property="ResizeMode"          Value="CanResize"/>
    </Style>

</ResourceDictionary>
