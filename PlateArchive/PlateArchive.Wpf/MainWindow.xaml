<Window x:Class="PlateArchive.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="PlateArchive" Height="720" Width="1160"
        WindowState="Maximized"
        MinWidth="1100" MinHeight="650"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource Window.Base}">

    <Window.Resources>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background"              Value="Transparent"/>
            <Setter Property="Foreground"              Value="{DynamicResource Brush.TextSecondary}"/>
            <Setter Property="BorderThickness"         Value="0"/>
            <Setter Property="Padding"                 Value="16,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize"                Value="{StaticResource FontSize.Body}"/>
            <Setter Property="FontFamily"              Value="{StaticResource FontFamily.Base}"/>
            <Setter Property="Cursor"                  Value="Hand"/>
            <Setter Property="SnapsToDevicePixels"     Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="{StaticResource Radius.M}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.SurfaceHover}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.ControlPressed}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- ── Status bar sincronizzazione (bottom) ──────────────── -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="0,1,0,0"
                Padding="16,5"
                Visibility="{Binding SyncStatusVisible, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
                <!-- Indicatore rotante durante la sync -->
                <TextBlock Text="⟳ "
                           FontSize="12"
                           Foreground="{DynamicResource Brush.Primary}"
                           VerticalAlignment="Center"
                           Visibility="{Binding IsSyncing, Converter={StaticResource BoolToVis}}"/>
                <TextBlock Text="{Binding SyncStatusText}"
                           FontSize="{StaticResource FontSize.Caption}"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SyncHasError}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource Brush.Error}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ── Layout principale ─────────────────────────────────── -->
        <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0"
                Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Logo / Titolo app -->
                <Border DockPanel.Dock="Top"
                        Background="{DynamicResource Brush.PrimaryLighter}"
                        Padding="20,18">
                    <StackPanel>
                        <TextBlock Text="PlateArchive"
                                   Foreground="{DynamicResource Brush.Primary}"
                                   FontSize="{StaticResource FontSize.Title}"
                                   FontWeight="{StaticResource FontWeight.Bold}"
                                   FontFamily="{StaticResource FontFamily.Base}"/>
                        <TextBlock Text="Gestione piastre"
                                   Foreground="{DynamicResource Brush.PrimaryLight}"
                                   FontSize="{StaticResource FontSize.Caption}"
                                   FontFamily="{StaticResource FontFamily.Base}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Separatore -->
                <Separator DockPanel.Dock="Top"/>

                <!-- Voci di navigazione -->
                <StackPanel DockPanel.Dock="Top" Margin="8,8">
                    <Button Content="Dashboard"
                            Command="{Binding NavigateToDashboardCommand}"
                            Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="Clienti"
                            Command="{Binding NavigateToClientiCommand}"
                            Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="Piastre"
                            Command="{Binding NavigateToPiastreCommand}"
                            Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="Macchine"
                            Command="{Binding NavigateToMacchineCommand}"
                            Style="{StaticResource NavButtonStyle}"/>

                    <!-- Sezione Impostazioni espandibile -->
                    <Separator Margin="4,8,4,4"/>
                    <Button Command="{Binding ToggleImpostazioniCommand}"
                            Style="{StaticResource NavButtonStyle}">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding ImpostazioniArrow}"
                                           FontSize="10" VerticalAlignment="Center"
                                           Margin="0,0,6,0"/>
                                <TextBlock Text="Impostazioni" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>
                    <StackPanel Margin="10,0,0,0"
                                Visibility="{Binding IsImpostazioniExpanded, Converter={StaticResource BoolToVis}}">
                        <Button Content="Formati macchina"
                                Command="{Binding NavigateToFormatiMacchinaCommand}"
                                Style="{StaticResource NavButtonStyle}"
                                Padding="16,10"/>
                        <Button Content="Categorie piastre"
                                Command="{Binding NavigateToCategoriePiastreCommand}"
                                Style="{StaticResource NavButtonStyle}"
                                Padding="16,10"/>
                        <Button Content="Produttori macchina"
                                Command="{Binding NavigateToProduttoriMacchinaCommand}"
                                Style="{StaticResource NavButtonStyle}"
                                Padding="16,10"/>
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Area contenuto -->
        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentViewModel}"
                        Background="{DynamicResource Brush.Background}"/>
        </Grid>

    </DockPanel>
</Window>
