<UserControl x:Class="PlateArchive.Wpf.Views.ClienteDettaglioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#757575"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>

        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="Foreground" Value="#212121"/>
        </Style>

        <Style x:Key="SmallButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#BDBDBD"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource SmallButtonStyle}">
            <Setter Property="Background" Value="#1E2A3B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#263340"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#BDBDBD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <DockPanel Background="#F0F2F5">

        <!-- Header: torna + nome cliente -->
        <Border DockPanel.Dock="Top" Background="White" Padding="16,12"
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <DockPanel>
                <Button DockPanel.Dock="Left"
                        Content="← Clienti"
                        Command="{Binding TornaIndietroCommand}"
                        Style="{StaticResource SmallButtonStyle}"
                        Margin="0,0,16,0"/>
                <TextBlock VerticalAlignment="Center"
                           FontSize="16" FontWeight="SemiBold" Foreground="#212121">
                    <Run Text="{Binding Cliente.RagioneSociale, FallbackValue='Caricamento…'}"/>
                    <Run Text="  "/>
                    <Run Text="{Binding Cliente.CodiceClienteGestionale}" Foreground="#757575" FontWeight="Normal" FontSize="13"/>
                </TextBlock>
            </DockPanel>
        </Border>

        <!-- Tab content -->
        <TabControl Background="Transparent" BorderThickness="0" Margin="24,20,24,24">

            <!-- Tab 1: Anagrafica -->
            <TabItem Header="Anagrafica">
                <ScrollViewer Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
                    <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" Padding="24">
                        <StackPanel MaxWidth="500" HorizontalAlignment="Left">
                            <TextBlock Text="Dati in sola lettura (fonte DB2)" FontSize="11"
                                       Foreground="#9E9E9E" Margin="0,0,0,20"/>

                            <TextBlock Text="Ragione Sociale" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Text="{Binding Cliente.RagioneSociale}" Style="{StaticResource ValueStyle}"/>

                            <TextBlock Text="Codice Gestionale" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Text="{Binding Cliente.CodiceClienteGestionale}" Style="{StaticResource ValueStyle}"/>

                            <TextBlock Text="Partita IVA" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Text="{Binding Cliente.PartitaIVA, FallbackValue='—'}" Style="{StaticResource ValueStyle}"/>

                            <TextBlock Text="Codice Fiscale" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Text="{Binding Cliente.CodiceFiscale, FallbackValue='—'}" Style="{StaticResource ValueStyle}"/>

                            <TextBlock Text="Stato" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Text="{Binding Cliente.StatoCliente}" Style="{StaticResource ValueStyle}"/>

                            <TextBlock Text="Ultima sincronizzazione" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Style="{StaticResource ValueStyle}">
                                <TextBlock.Text>
                                    <Binding Path="Cliente.DataUltimaSincronizzazione"
                                             StringFormat="dd/MM/yyyy HH:mm"
                                             FallbackValue="Mai sincronizzato"/>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 2: Macchine -->
            <TabItem Header="Macchine">
                <DockPanel Margin="0,16,0,0">

                    <!-- Toolbar -->
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#424242"
                                   Text="Macchine associate"/>
                        <Button DockPanel.Dock="Right"
                                Content="+ Aggiungi"
                                Command="{Binding AggiungiMacchinaCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"/>
                    </DockPanel>

                    <!-- Form aggiungi macchina (inline, collassabile) -->
                    <Border DockPanel.Dock="Top"
                            Visibility="{Binding IsAggiungiMacchinaVisible, Converter={StaticResource BoolToVis}}"
                            Background="White" BorderBrush="#90CAF9" BorderThickness="1"
                            Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Nuova associazione macchina"
                                       FontWeight="SemiBold" Margin="0,0,0,12"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Macchina *" FontSize="11" Foreground="#757575" Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding MacchineDisponibili}"
                                              SelectedItem="{Binding MacchinaSelezionata}"
                                              DisplayMemberPath="NomeMacchina"
                                              Padding="8,6"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Matricola" FontSize="11" Foreground="#757575" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding MatricolaNuova, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="8,6" BorderBrush="#BDBDBD"/>
                                </StackPanel>

                                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Bottom">
                                    <Button Content="Salva"
                                            Command="{Binding ConfermaAggiungiMacchinaCommand}"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Margin="0,0,8,0"/>
                                    <Button Content="Annulla"
                                            Command="{Binding AnnullaAggiungiMacchinaCommand}"
                                            Style="{StaticResource SmallButtonStyle}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Lista macchine -->
                    <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
                        <DataGrid ItemsSource="{Binding Macchine}"
                                  AutoGenerateColumns="False" CanUserAddRows="False"
                                  IsReadOnly="True" HeadersVisibility="Column"
                                  Background="White" AlternatingRowBackground="#FAFAFA"
                                  BorderThickness="0" RowHeight="36" ColumnHeaderHeight="34">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Macchina"
                                                   Binding="{Binding MacchinaStandard.NomeMacchina}"
                                                   Width="*"/>
                                <DataGridTextColumn Header="Matricola"
                                                   Binding="{Binding Matricola}"
                                                   Width="140"/>
                                <DataGridTextColumn Header="Codice interno"
                                                   Binding="{Binding CodiceInternoCliente}"
                                                   Width="130"/>
                                <DataGridCheckBoxColumn Header="Att."
                                                       Binding="{Binding Attiva}"
                                                       Width="50"/>
                                <DataGridTemplateColumn Header="" Width="60">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Rimuovi" FontSize="11" Padding="6,3"
                                                    Foreground="#D32F2F" BorderBrush="#FFCDD2"
                                                    Cursor="Hand"
                                                    Command="{Binding DataContext.RimuoviMacchinaCommand,
                                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                </DockPanel>
            </TabItem>

            <!-- Tab 3: Piastre -->
            <TabItem Header="Piastre">
                <DockPanel Margin="0,16,0,0">

                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#424242"
                                   Text="Piastre associate"/>
                        <Button DockPanel.Dock="Right"
                                Content="+ Aggiungi"
                                Command="{Binding AggiungiPiastraCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"/>
                    </DockPanel>

                    <!-- Form aggiungi piastra (inline, collassabile) -->
                    <Border DockPanel.Dock="Top"
                            Visibility="{Binding IsAggiungiPiastraVisible, Converter={StaticResource BoolToVis}}"
                            Background="White" BorderBrush="#90CAF9" BorderThickness="1"
                            Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Nuova associazione piastra"
                                       FontWeight="SemiBold" Margin="0,0,0,12"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Selezione piastra -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Piastra *" FontSize="11" Foreground="#757575" Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding PiastreDisponibili}"
                                              SelectedItem="{Binding PiastraSelezionata}"
                                              Padding="8,6">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock>
                                                    <Run Text="{Binding CodicePiastra}" FontWeight="SemiBold"/>
                                                    <Run Text=" — "/>
                                                    <Run Text="{Binding Descrizione}"/>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Macchina cliente (opzionale) -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Macchina cliente (opzionale)" FontSize="11" Foreground="#757575" Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding Macchine}"
                                              SelectedItem="{Binding MacchinaPerPiastra}"
                                              DisplayMemberPath="MacchinaStandard.NomeMacchina"
                                              Padding="8,6"/>
                                </StackPanel>

                                <!-- Bottoni azione -->
                                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Bottom">
                                    <Button Content="Salva"
                                            Command="{Binding ConfermaAggiungiPiastraCommand}"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Margin="0,0,8,0"/>
                                    <Button Content="Annulla"
                                            Command="{Binding AnnullaAggiungiPiastraCommand}"
                                            Style="{StaticResource SmallButtonStyle}"/>
                                </StackPanel>
                            </Grid>

                            <!-- Errore piastra già associata -->
                            <TextBlock Text="{Binding ErrorePiastraEsistente}"
                                       Foreground="#C62828" FontSize="12" Margin="0,10,0,0"
                                       Visibility="{Binding IsErrorePiastraVisible, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </Border>

                    <!-- Errore apertura file disegno -->
                    <TextBlock Text="{Binding ErroreDisegno}"
                               Foreground="#C62828" FontSize="12"
                               Margin="0,0,0,6" TextWrapping="Wrap"
                               Visibility="{Binding IsErroreDisegnoVisible, Converter={StaticResource BoolToVis}}"/>

                    <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
                        <DataGrid ItemsSource="{Binding Piastre}"
                                  AutoGenerateColumns="False" CanUserAddRows="False"
                                  IsReadOnly="True" HeadersVisibility="Column"
                                  Background="White" AlternatingRowBackground="#FAFAFA"
                                  BorderThickness="0" RowHeight="36" ColumnHeaderHeight="34">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Codice Piastra"
                                                   Binding="{Binding Piastra.CodicePiastra}"
                                                   Width="140"/>
                                <DataGridTextColumn Header="Descrizione"
                                                   Binding="{Binding Piastra.Descrizione}"
                                                   Width="*"/>
                                <DataGridTextColumn Header="Macchina"
                                                   Binding="{Binding ClienteMacchina.MacchinaStandard.NomeMacchina}"
                                                   Width="160"/>
                                <DataGridTextColumn Header="Stato"
                                                   Binding="{Binding Stato}"
                                                   Width="100"/>
                                <DataGridTemplateColumn Header="" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="Apri disegno" FontSize="11" Padding="6,3"
                                                        Margin="0,0,6,0" Cursor="Hand"
                                                        Command="{Binding DataContext.AprirDisegnoCommand,
                                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="Rimuovi" FontSize="11" Padding="6,3"
                                                        Foreground="#D32F2F" BorderBrush="#FFCDD2"
                                                        Cursor="Hand"
                                                        Command="{Binding DataContext.RimuoviPiastraCommand,
                                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                </DockPanel>
            </TabItem>

            <!-- Tab 4: Compatibilità -->
            <TabItem Header="Compatibilità">
                <DockPanel Margin="0,16,0,0">
                    <TextBlock DockPanel.Dock="Top"
                               Text="Piastre compatibili con le macchine di questo cliente"
                               FontSize="13" FontWeight="SemiBold" Foreground="#424242"
                               Margin="0,0,0,12"/>
                    <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
                        <DataGrid ItemsSource="{Binding Compatibilita}"
                                  AutoGenerateColumns="False" CanUserAddRows="False"
                                  IsReadOnly="True" HeadersVisibility="Column"
                                  Background="White" AlternatingRowBackground="#FAFAFA"
                                  BorderThickness="0" RowHeight="36" ColumnHeaderHeight="34">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Macchina"
                                                   Binding="{Binding NomeMacchina}"
                                                   Width="180"/>
                                <DataGridTextColumn Header="Piastra"
                                                   Binding="{Binding CodicePiastra}"
                                                   Width="140"/>
                                <DataGridTextColumn Header="Descrizione"
                                                   Binding="{Binding DescrizionePiastra}"
                                                   Width="*"/>
                                <DataGridCheckBoxColumn Header="Att."
                                                       Binding="{Binding Attiva}"
                                                       Width="50"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </DockPanel>
            </TabItem>

        </TabControl>
    </DockPanel>
</UserControl>
