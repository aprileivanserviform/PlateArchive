<UserControl x:Class="PlateArchive.Wpf.Views.ClientiView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <DockPanel Background="#F0F2F5">

        <!-- Header: titolo + barra ricerca + sincronizzazione -->
        <Border DockPanel.Dock="Top" Background="White" Padding="24,16"
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <DockPanel>
                <!-- Titolo + bottone Sincronizza sulla stessa riga -->
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                    <Button DockPanel.Dock="Right"
                            Content="{Binding SincronizzaLabel}"
                            Command="{Binding SincronizzaCommand}"
                            Padding="14,7" Cursor="Hand"
                            Background="#1565C0" Foreground="White"
                            BorderThickness="0"
                            IsEnabled="{Binding IsSincronizzando, Converter={StaticResource BoolToVis},
                                        ConverterParameter=invert}"
                            VerticalAlignment="Center">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#1565C0"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="14,7"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#1976D2"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Background" Value="#BDBDBD"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <TextBlock Text="Clienti"
                               FontSize="20" FontWeight="SemiBold" Foreground="#212121"
                               VerticalAlignment="Center"/>
                </DockPanel>

                <!-- Messaggio esito sincronizzazione -->
                <Border DockPanel.Dock="Top"
                        Margin="0,0,0,10" Padding="10,7"
                        Visibility="{Binding IsEsitoVisible, Converter={StaticResource BoolToVis}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding EsitoIsErrore}" Value="True">
                                    <Setter Property="Background"   Value="#FFEBEE"/>
                                    <Setter Property="BorderBrush"  Value="#EF9A9A"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding EsitoIsOk}" Value="True">
                                    <Setter Property="Background"   Value="#E8F5E9"/>
                                    <Setter Property="BorderBrush"  Value="#A5D6A7"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding EsitoSincronizzazione}"
                               FontSize="12" TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding EsitoIsErrore}" Value="True">
                                        <Setter Property="Foreground" Value="#C62828"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding EsitoIsOk}" Value="True">
                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>

                <!-- Barra filtri -->
                <DockPanel DockPanel.Dock="Top">
                    <ComboBox DockPanel.Dock="Right"
                              ItemsSource="{Binding StatiFiltro}"
                              SelectedItem="{Binding FiltroStatoSelezionato}"
                              Width="120" Margin="10,0,0,0"
                              VerticalAlignment="Center"/>
                    <TextBox Text="{Binding FiltroRicerca, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,7" BorderBrush="#BDBDBD" FontSize="14"/>
                </DockPanel>
            </DockPanel>
        </Border>

        <!-- Lista clienti -->
        <Border Background="White" Margin="24,20" BorderBrush="#E0E0E0" BorderThickness="1">
            <DataGrid ItemsSource="{Binding ClientiFiltrati}"
                      AutoGenerateColumns="False" CanUserAddRows="False"
                      IsReadOnly="True" HeadersVisibility="Column"
                      SelectionMode="Single" GridLinesVisibility="Horizontal"
                      Background="White" RowBackground="White"
                      AlternatingRowBackground="#FAFAFA" BorderThickness="0"
                      RowHeight="36" ColumnHeaderHeight="36">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <EventSetter Event="MouseDoubleClick" Handler="Row_MouseDoubleClick"/>
                        <Setter Property="Cursor" Value="Hand"/>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Codice"
                                       Binding="{Binding CodiceClienteGestionale}"
                                       Width="140"/>
                    <DataGridTextColumn Header="Ragione Sociale"
                                       Binding="{Binding RagioneSociale}"
                                       Width="*"/>
                    <DataGridTextColumn Header="P.IVA"
                                       Binding="{Binding PartitaIVA}"
                                       Width="130"/>
                    <DataGridTextColumn Header="Stato"
                                       Binding="{Binding StatoCliente}"
                                       Width="100"/>
                    <DataGridTemplateColumn Header="" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Apri"
                                        FontSize="11"
                                        Padding="8,4"
                                        Command="{Binding DataContext.AprirDettaglioCommand,
                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Cursor="Hand"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

    </DockPanel>
</UserControl>
