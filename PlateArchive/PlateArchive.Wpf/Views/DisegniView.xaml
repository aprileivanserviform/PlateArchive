<UserControl x:Class="PlateArchive.Wpf.Views.DisegniView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
    DisegniView — elenco disegni tecnici (uno per piastra).
    Layout: Header (titolo + filtri) | Grid orizzontale (lista | pannello modifica metadati)

    I disegni vengono creati automaticamente dal drag-drop in PiastreView.
    Qui si modificano: percorso file, revisione, formato, stato, note.
    Le righe "Da verificare" sono evidenziate con sfondo ambra (DataTrigger in RowStyleDisegni).
    "Apri file" usa Process.Start con UseShellExecute per aprire AutoCAD, PDF, ecc.
    -->

    <UserControl.Resources>
        <!-- Riga evidenziata per DaVerificare — estende lo stile ByteLab -->
        <Style x:Key="RowStyleDisegni" TargetType="DataGridRow" BasedOn="{StaticResource DataGridRow.Base}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Stato}" Value="DaVerificare">
                    <Setter Property="Background" Value="{DynamicResource Brush.WarningSurface}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <DockPanel Background="{DynamicResource Brush.Background}">

        <!-- ── Header ─────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource Brush.Surface}"
                Padding="24,14"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="Disegni"
                           Style="{StaticResource TextBlock.Title}"
                           Margin="0,0,0,10"/>
                <DockPanel>
                    <ComboBox DockPanel.Dock="Right"
                              ItemsSource="{Binding StatiFiltro}"
                              SelectedItem="{Binding FiltroStatoSelezionato}"
                              Width="130" Margin="10,0,0,0"
                              VerticalAlignment="Center"/>
                    <TextBox Text="{Binding FiltroRicerca, UpdateSourceTrigger=PropertyChanged}"/>
                </DockPanel>
            </StackPanel>
        </Border>

        <!-- ── Body ───────────────────────────────────────────── -->
        <Grid Margin="24,20,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- Lista disegni -->
            <Border Grid.Column="0"
                    Background="{DynamicResource Brush.Surface}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1">
                <DataGrid ItemsSource="{Binding DisegniFiltrati}"
                          SelectedItem="{Binding DisegnoSelezionato, Mode=TwoWay}"
                          CanUserAddRows="False" IsReadOnly="True"
                          RowHeight="36"
                          RowStyle="{StaticResource RowStyleDisegni}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Codice"
                                           Binding="{Binding CodiceDisegno}"
                                           Width="130"/>
                        <DataGridTextColumn Header="Piastra"
                                           Binding="{Binding Piastra.CodicePiastra}"
                                           Width="120"/>
                        <DataGridTextColumn Header="Rev."
                                           Binding="{Binding Revisione}"
                                           Width="45"/>
                        <DataGridTextColumn Header="Formato"
                                           Binding="{Binding Formato}"
                                           Width="60"/>
                        <DataGridTextColumn Header="Stato"
                                           Binding="{Binding Stato}"
                                           Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Pannello modifica -->
            <Border Grid.Column="2"
                    Visibility="{Binding IsDetailVisible, Converter={StaticResource BoolToVis}}"
                    Background="{DynamicResource Brush.Surface}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.M}"
                    Padding="20" VerticalAlignment="Top">
                <StackPanel>
                    <!-- Titolo -->
                    <TextBlock Style="{StaticResource TextBlock.Subtitle}" Margin="0,0,0,16">
                        <Run Text="Modifica: "/>
                        <Run Text="{Binding DisegnoSelezionato.CodiceDisegno}"/>
                    </TextBlock>

                    <!-- Errore file non trovato -->
                    <Border Background="{DynamicResource Brush.ErrorSurface}"
                            BorderBrush="{DynamicResource Brush.Error}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource Radius.S}"
                            Padding="10,8" Margin="0,0,0,12"
                            Visibility="{Binding IsErroreFileVisible, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding ErroreFileNonTrovato}"
                                   TextWrapping="Wrap"
                                   FontSize="{StaticResource FontSize.Caption}"
                                   Foreground="{DynamicResource Brush.Error}"/>
                    </Border>

                    <!-- Percorso file -->
                    <TextBlock Text="Percorso file" Style="{StaticResource FieldLabel}"/>
                    <DockPanel Margin="0,0,0,10">
                        <Button DockPanel.Dock="Right"
                                Content="Sfoglia"
                                Command="{Binding SfogliaFileCommand}"
                                Style="{StaticResource Button.Secondary}"
                                Margin="6,0,0,0"/>
                        <TextBox Text="{Binding FormPercorsoFile, UpdateSourceTrigger=PropertyChanged}"/>
                    </DockPanel>

                    <!-- Revisione + Formato -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Revisione" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding FormRevisione, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Formato" Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{Binding FormatiDisponibili}"
                                      Text="{Binding FormFormato, UpdateSourceTrigger=PropertyChanged}"
                                      IsEditable="True"/>
                        </StackPanel>
                    </Grid>

                    <!-- Stato + Data ultima modifica -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Stato" Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{Binding StatiDisegno}"
                                      SelectedItem="{Binding FormStato}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Ult. modifica file" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Margin="0,6,0,0">
                                <TextBlock.Text>
                                    <Binding Path="DisegnoSelezionato.DataUltimaModificaFile"
                                             StringFormat="dd/MM/yyyy"
                                             FallbackValue="—"/>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Grid>

                    <!-- Note -->
                    <TextBlock Text="Note" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding FormNote, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FieldBox}"
                             AcceptsReturn="True" Height="60"/>

                    <!-- Bottoni -->
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <Button Content="Salva"
                                Command="{Binding SalvaCommand}"
                                Margin="0,0,10,0"/>
                        <Button Content="Apri file"
                                Command="{Binding AprirFileCommand}"
                                Style="{StaticResource Button.Secondary}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Placeholder nessun disegno selezionato -->
            <Border Grid.Column="2"
                    Visibility="{Binding IsNessunDisegnoSelezionato, Converter={StaticResource BoolToVis}}"
                    Background="{DynamicResource Brush.Surface}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.M}">
                <TextBlock Text="Seleziona un disegno dalla lista per modificarne i metadati."
                           Foreground="{DynamicResource Brush.TextSecondary}"
                           FontSize="{StaticResource FontSize.Caption}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           TextWrapping="Wrap" Padding="20"/>
            </Border>

        </Grid>
    </DockPanel>
</UserControl>
