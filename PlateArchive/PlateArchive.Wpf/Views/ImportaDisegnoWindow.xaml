<Window x:Class="PlateArchive.Wpf.Views.ImportaDisegnoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Importa disegno"
        Width="560" SizeToContent="Height"
        MaxHeight="860"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{StaticResource Window.Base}">

    <DockPanel Margin="24">

        <!-- ── Header: info file ─────────────────────────────────── -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <TextBlock Text="Importa disegno"
                       Style="{StaticResource TextBlock.Title}"
                       Margin="0,0,0,6"/>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding NomeFile}"
                           Style="{StaticResource TextBlock.BodyLarge}"
                           FontWeight="{StaticResource FontWeight.SemiBold}"
                           Foreground="{DynamicResource Brush.Primary}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding TitoloStato}"
                           FontSize="{StaticResource FontSize.Caption}"
                           VerticalAlignment="Center"
                           Margin="14,0,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Success}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDisegnoEsistente}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource Brush.Warning}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </StackPanel>

        <!-- ── Pulsanti fondo ────────────────────────────────────── -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="{Binding TestoConferma}"
                    Command="{Binding ConfermaCommand}"
                    Margin="0,0,10,0"/>
            <Button Content="Annulla"
                    Command="{Binding AnnullaCommand}"
                    Style="{StaticResource Button.Secondary}"/>
        </StackPanel>

        <!-- ── Corpo (scrollabile) ──────────────────────────────── -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- ══ CASO A: disegno già nel sistema ════════════════ -->
                <StackPanel Visibility="{Binding IsDisegnoEsistente, Converter={StaticResource BoolToVis}}"
                            Margin="0,0,0,4">

                    <!-- Piastra collegata (read-only) -->
                    <Border Style="{StaticResource Card.Subtle}" Padding="12,10" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Piastra collegata"
                                       Style="{StaticResource TextBlock.Caption}"
                                       Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding PiastraGiaAssociata.CodicePiastra}"
                                           FontWeight="{StaticResource FontWeight.SemiBold}"
                                           Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding PiastraGiaAssociata.Descrizione, TargetNullValue=''}"
                                           Foreground="{DynamicResource Brush.TextSecondary}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Clienti già associati -->
                    <TextBlock Text="Clienti già associati"
                               Style="{StaticResource TextBlock.Caption}"
                               Margin="0,0,0,6"/>
                    <Border BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1" MaxHeight="160" Margin="0,0,0,16">
                        <DataGrid ItemsSource="{Binding ClientiGiaAssociati}"
                                  CanUserAddRows="False" IsReadOnly="True"
                                  RowHeight="30" ColumnHeaderHeight="28">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Codice"
                                                   Binding="{Binding Cliente.CodiceClienteGestionale}"
                                                   Width="90"/>
                                <DataGridTextColumn Header="Cliente"
                                                   Binding="{Binding Cliente.RagioneSociale}"
                                                   Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </StackPanel>

                <!-- ══ CASO B: nuovo disegno → scelta piastra ═════════ -->
                <StackPanel Visibility="{Binding IsNuovoDisegno, Converter={StaticResource BoolToVis}}">
                    <Separator Margin="0,0,0,16"/>
                    <TextBlock Text="Associa a:"
                               Style="{StaticResource TextBlock.BodyLarge}"
                               Margin="0,0,0,10"/>

                    <!-- Piastra esistente -->
                    <RadioButton Content="Piastra esistente"
                                 IsChecked="{Binding IsAssociaEsistenteMode}"
                                 Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding PiastреDisponibili}"
                              SelectedItem="{Binding PiastraSelezionata}"
                              IsEnabled="{Binding IsAssociaEsistenteMode}"
                              Margin="20,0,0,16">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding CodicePiastra}" FontWeight="SemiBold" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding Descrizione, TargetNullValue=''}"
                                               Foreground="{DynamicResource Brush.TextSecondary}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Crea nuova piastra -->
                    <RadioButton Content="Crea nuova piastra"
                                 IsChecked="{Binding IsCreaNuovaPiastraMode}"
                                 Margin="0,0,0,10"/>

                    <StackPanel IsEnabled="{Binding IsCreaNuovaPiastraMode}"
                                Margin="20,0,0,0">

                        <TextBlock Text="Codice piastra *" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding FormCodicePiastra, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FieldBox}"/>

                        <TextBlock Text="Codice articolo gestionale" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding FormCodiceArticolo, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FieldBox}"/>

                        <TextBlock Text="Descrizione" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding FormDescrizione, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FieldBox}"/>

                        <TextBlock Text="Stato" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding StatiPiastra}"
                                  SelectedItem="{Binding FormStato}"
                                  Margin="0,0,0,10"/>

                        <TextBlock Text="Formato macchina" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding FormatiMacchine}"
                                  SelectedItem="{Binding FormFormato}"
                                  DisplayMemberPath="NomeFormato"
                                  Margin="0,0,0,10"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Categoria" Style="{StaticResource FieldLabel}"/>
                                <ComboBox ItemsSource="{Binding CategoriePiastre}"
                                          SelectedItem="{Binding FormCategoria}"
                                          DisplayMemberPath="Descrizione"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Peso (kg)" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding FormPeso, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Misure (mm)" Style="{StaticResource FieldLabel}"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Larghezza" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding FormLarghezza, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Altezza" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding FormAltezza, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Spessore" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding FormSpessore, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="6">
                                <TextBlock Text="Durezza" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding FormDurezza, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Note" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding FormNote, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FieldBox}"
                                 AcceptsReturn="True" Height="60"/>

                    </StackPanel>
                </StackPanel>

                <!-- ══ Sezione: associazione cliente (comune ai due casi) ══ -->
                <Separator Margin="0,4,0,12"/>
                <TextBlock Text="{Binding TitoloSezioneCliente}"
                           Style="{StaticResource TextBlock.BodyLarge}"
                           Margin="0,0,0,10"/>

                <!-- Cliente selezionato (chip con X) -->
                <Border Visibility="{Binding IsClienteSelezionatoVisible, Converter={StaticResource BoolToVis}}"
                        Background="{DynamicResource Brush.PrimarySubtle}"
                        BorderBrush="{DynamicResource Brush.Primary}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource Radius.S}"
                        Padding="10,6"
                        Margin="0,0,0,8">
                    <DockPanel>
                        <Button DockPanel.Dock="Right"
                                Style="{StaticResource Button.Icon}"
                                Command="{Binding RimuoviClienteCommand}"
                                ToolTip="Rimuovi cliente"
                                Margin="8,0,0,0">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="10"/>
                        </Button>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock FontWeight="{StaticResource FontWeight.SemiBold}"
                                       Text="{Binding FormCliente.RagioneSociale}"/>
                            <TextBlock Text="{Binding FormCliente.CodiceClienteGestionale}"
                                       FontSize="{StaticResource FontSize.Caption}"
                                       Foreground="{DynamicResource Brush.TextSecondary}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Ricerca cliente -->
                <Grid Visibility="{Binding IsClienteSearchVisible, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBox Grid.Row="0"
                             Text="{Binding FiltroCliente, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Suggerimenti dropdown -->
                    <Border Grid.Row="1"
                            Visibility="{Binding IsClienteSuggerimentiVisible, Converter={StaticResource BoolToVis}}"
                            Background="{DynamicResource Brush.Surface}"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource Radius.S}"
                            Margin="0,2,0,0">
                        <ItemsControl ItemsSource="{Binding ClientiSuggeriti}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource Button.Ghost}"
                                            HorizontalContentAlignment="Left"
                                            HorizontalAlignment="Stretch"
                                            Command="{Binding DataContext.SelezionaClienteCommand,
                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Padding="10,6">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding CodiceClienteGestionale}"
                                                       FontWeight="{StaticResource FontWeight.SemiBold}"
                                                       Foreground="{DynamicResource Brush.TextSecondary}"
                                                       MinWidth="70"
                                                       Margin="0,0,10,0"/>
                                            <TextBlock Text="{Binding RagioneSociale}"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </Grid>

                <TextBlock FontSize="{StaticResource FontSize.Caption}"
                           Margin="0,4,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text"       Value="Lascia vuoto per non associare nessun cliente ora."/>
                            <Setter Property="Foreground" Value="{DynamicResource Brush.TextDisabled}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDisegnoEsistente}" Value="True">
                                    <Setter Property="Text" Value="Opzionale — lascia vuoto per chiudere senza aggiungere."/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsClienteObbligatorio}" Value="True">
                                    <Setter Property="Text"       Value="Obbligatorio per le piastre Speciale Cliente."/>
                                    <Setter Property="Foreground" Value="{DynamicResource Brush.Warning}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Errore -->
                <Border Background="{DynamicResource Brush.ErrorSurface}"
                        BorderBrush="{DynamicResource Brush.Error}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource Radius.S}"
                        Padding="10,8"
                        Margin="0,12,0,0"
                        Visibility="{Binding IsErroreVisible, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding Errore}"
                               TextWrapping="Wrap"
                               FontSize="{StaticResource FontSize.Caption}"
                               Foreground="{DynamicResource Brush.Error}"/>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
