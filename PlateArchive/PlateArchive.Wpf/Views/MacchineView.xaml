<UserControl x:Class="PlateArchive.Wpf.Views.MacchineView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DockPanel Background="{DynamicResource Brush.Background}">

        <!-- ── Header ─────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource Brush.Surface}"
                Padding="24,14"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="+ Nuova macchina"
                        Command="{Binding NuovaCommand}"/>

                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Macchine Standard"
                               Style="{StaticResource TextBlock.Title}"
                               Margin="0,0,0,10"/>
                    <DockPanel>
                        <CheckBox DockPanel.Dock="Right"
                                  Content="Solo attive"
                                  IsChecked="{Binding SoloAttive}"
                                  VerticalAlignment="Center"
                                  Margin="16,0,0,0"/>
                        <ComboBox DockPanel.Dock="Right"
                                  ItemsSource="{Binding FamiglieFiltro}"
                                  SelectedItem="{Binding FiltroFamiglia}"
                                  Width="130" Margin="12,0,0,0"/>
                        <TextBox Text="{Binding FiltroRicerca, UpdateSourceTrigger=PropertyChanged}"/>
                    </DockPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Body ───────────────────────────────────────────── -->
        <Grid Margin="24,20,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- Lista macchine -->
            <Border Grid.Column="0"
                    Background="{DynamicResource Brush.Surface}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1">
                <DataGrid ItemsSource="{Binding MacchineFiltrate}"
                          SelectedItem="{Binding MacchinaSelezionata, Mode=TwoWay}"
                          CanUserAddRows="False" IsReadOnly="True"
                          RowHeight="36">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource DataGridRow.Base}">
                            <EventSetter Event="MouseDoubleClick" Handler="Row_MouseDoubleClick"/>
                            <Setter Property="Cursor" Value="Hand"/>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Codice"
                                           Binding="{Binding CodiceMacchina}"
                                           Width="160"/>
                        <DataGridTextColumn Header="Nome"
                                           Binding="{Binding NomeMacchina}"
                                           Width="*"/>
                        <DataGridTextColumn Header="Famiglia"
                                           Binding="{Binding Famiglia.NomeFamiglia}"
                                           Width="110"/>
                        <DataGridTextColumn Header="Produttore"
                                           Binding="{Binding Produttore.NomeProduttore}"
                                           Width="110"/>
                        <DataGridCheckBoxColumn Header="Att."
                                               Binding="{Binding Attiva}"
                                               Width="45"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Pannello destra: dettaglio OPPURE form -->
            <Grid Grid.Column="2">

                <!-- ── Form creazione/modifica ─────────────────── -->
                <Border Visibility="{Binding IsFormVisible, Converter={StaticResource BoolToVis}}"
                        Background="{DynamicResource Brush.Surface}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource Radius.M}"
                        Padding="20" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="{Binding FormTitolo}"
                                   Style="{StaticResource TextBlock.Subtitle}"
                                   Margin="0,0,0,16"/>

                        <!-- Avviso duplicato -->
                        <Border Background="{DynamicResource Brush.WarningSurface}"
                                BorderBrush="{DynamicResource Brush.Warning}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource Radius.S}"
                                Padding="10,8" Margin="0,0,0,12"
                                Visibility="{Binding IsAvvisoDuplicatoVisible, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding AvvisoDuplicato}"
                                       TextWrapping="Wrap"
                                       FontSize="{StaticResource FontSize.Caption}"
                                       Foreground="{DynamicResource Brush.Warning}"/>
                        </Border>

                        <TextBlock Text="Codice macchina *" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding FormCodiceMacchina, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FieldBox}"/>

                        <TextBlock Text="Nome macchina *" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding FormNomeMacchina, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FieldBox}"/>

                        <TextBlock Text="Famiglia" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding FamiglieMacchine}"
                                  SelectedItem="{Binding FormFamigliaSelezionata}"
                                  DisplayMemberPath="NomeFamiglia"
                                  Style="{StaticResource FieldBox}"/>

                        <TextBlock Text="Produttore" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding ProduttoriMacchine}"
                                  SelectedItem="{Binding FormProduttoreSelezionato}"
                                  DisplayMemberPath="NomeProduttore"
                                  Style="{StaticResource FieldBox}"/>

                        <!-- Misure -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Larghezza (mm)" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding FormLarghezza, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FieldBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Altezza (mm)" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding FormAltezza, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FieldBox}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Versione" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding FormVersione, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FieldBox}"/>

                        <TextBlock Text="Note" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding FormNote, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FieldBox}"
                                 AcceptsReturn="True" Height="60"/>

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Salva"
                                    Command="{Binding SalvaCommand}"
                                    Margin="0,0,10,0"/>
                            <Button Content="Annulla"
                                    Command="{Binding AnnullaFormCommand}"
                                    Style="{StaticResource Button.Secondary}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ── Dettaglio macchina selezionata ──────────── -->
                <Border Visibility="{Binding IsDetailVisible, Converter={StaticResource BoolToVis}}"
                        Background="{DynamicResource Brush.Surface}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource Radius.M}"
                        Padding="20">
                    <DockPanel>
                        <!-- Header dettaglio -->
                        <Border DockPanel.Dock="Top" Margin="0,0,0,16">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="{Binding MacchinaSelezionata.NomeMacchina}"
                                               Style="{StaticResource TextBlock.BodyLarge}"
                                               FontWeight="{StaticResource FontWeight.SemiBold}"/>
                                    <TextBlock Text="{Binding MacchinaSelezionata.CodiceMacchina}"
                                               Style="{StaticResource TextBlock.Caption}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                            VerticalAlignment="Top">
                                    <Button Content="Modifica"
                                            Command="{Binding ModificaCommand}"
                                            Style="{StaticResource Button.Secondary}"
                                            Margin="0,0,8,0"/>
                                    <Button Content="{Binding ToggleAttivaLabel}"
                                            Command="{Binding ToggleAttivaCommand}"
                                            Style="{StaticResource Button.Ghost}"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <!-- Info base -->
                        <Border DockPanel.Dock="Top" Margin="0,0,0,16"
                                Style="{StaticResource Card.Subtle}"
                                Padding="12,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Famiglia" Style="{StaticResource TextBlock.Caption}"/>
                                    <TextBlock Text="{Binding MacchinaSelezionata.Famiglia.NomeFamiglia, FallbackValue='—'}"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="Larghezza (mm)" Style="{StaticResource TextBlock.Caption}"/>
                                    <TextBlock Text="{Binding MacchinaSelezionata.LarghezzaMm, FallbackValue='—'}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Produttore" Style="{StaticResource TextBlock.Caption}"/>
                                    <TextBlock Text="{Binding MacchinaSelezionata.Produttore.NomeProduttore, FallbackValue='—'}"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="Altezza (mm)" Style="{StaticResource TextBlock.Caption}"/>
                                    <TextBlock Text="{Binding MacchinaSelezionata.AltezzaMm, FallbackValue='—'}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Versione -->
                        <Border DockPanel.Dock="Top" Margin="0,0,0,16"
                                Style="{StaticResource Card.Subtle}"
                                Padding="12,10">
                            <StackPanel>
                                <TextBlock Text="Versione" Style="{StaticResource TextBlock.Caption}"/>
                                <TextBlock Text="{Binding MacchinaSelezionata.Versione, FallbackValue='—'}"/>
                            </StackPanel>
                        </Border>

                        <!-- Piastre compatibili -->
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Piastre compatibili"
                                   Style="{StaticResource SectionTitle}"/>
                        <Border DockPanel.Dock="Top"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1"
                                Margin="0,0,0,16" MaxHeight="180">
                            <DataGrid ItemsSource="{Binding PiastreCompatibili}"
                                      CanUserAddRows="False" IsReadOnly="True"
                                      RowHeight="30" ColumnHeaderHeight="30">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Codice"
                                                       Binding="{Binding Piastra.CodicePiastra}"
                                                       Width="120"/>
                                    <DataGridTextColumn Header="Descrizione"
                                                       Binding="{Binding Piastra.Descrizione}"
                                                       Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <!-- Clienti associati -->
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Clienti che la possiedono"
                                   Style="{StaticResource SectionTitle}"/>
                        <Border DockPanel.Dock="Top"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1"
                                MaxHeight="150">
                            <DataGrid ItemsSource="{Binding ClientiAssociati}"
                                      CanUserAddRows="False" IsReadOnly="True"
                                      RowHeight="30" ColumnHeaderHeight="30">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Ragione Sociale"
                                                       Binding="{Binding Cliente.RagioneSociale}"
                                                       Width="*"/>
                                    <DataGridTextColumn Header="Matricola"
                                                       Binding="{Binding Matricola}"
                                                       Width="90"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </DockPanel>
                </Border>

            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
