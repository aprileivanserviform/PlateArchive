<UserControl x:Class="PlateArchive.Wpf.Views.MacchineView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
    MacchineView — schermata catalogo modelli macchina.
    Layout: DockPanel verticale (Header + filtri | Grid orizzontale lista | pannello destra)

    Pannello destra mostra (Visibility alternata):
      - Form creazione/modifica (IsFormVisible = true)
      - Dettaglio macchina: piastre compatibili + clienti associati (IsDetailVisible = true)

    Funzionalità speciali:
      - "+ Aggiungi" piastra compatibile: ComboBox inline con ItemTemplate (codice + descrizione)
      - "Rimuovi" sulla riga della piastra compatibile → RimuoviCompatibilitaCommand
      - "Disabilita/Abilita" → ToggleAttivaCommand (macchine disabilitate spariscono con filtro SoloAttive)
    -->

    <DockPanel Background="{DynamicResource Brush.Background}">

        <!-- ── Header ─────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource Brush.Surface}"
                Padding="24,14"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="+ Nuova macchina"
                        Command="{Binding NuovaCommand}"/>

                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Macchine Standard"
                               Style="{StaticResource TextBlock.Title}"
                               Margin="0,0,0,10"/>
                    <DockPanel>
                        <CheckBox DockPanel.Dock="Right"
                                  Content="Solo attive"
                                  IsChecked="{Binding SoloAttive}"
                                  VerticalAlignment="Center"
                                  Margin="16,0,0,0"/>
                        <ComboBox DockPanel.Dock="Right"
                                  ItemsSource="{Binding FormatiFiltro}"
                                  SelectedItem="{Binding FiltroFormato}"
                                  Width="130" Margin="12,0,0,0"/>
                        <TextBox Text="{Binding FiltroRicerca, UpdateSourceTrigger=PropertyChanged}"/>
                    </DockPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Body ───────────────────────────────────────────── -->
        <Grid Margin="24,20,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="520"/>
            </Grid.ColumnDefinitions>

            <!-- Lista macchine -->
            <Border Grid.Column="0"
                    Background="{DynamicResource Brush.Surface}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1">
                <DataGrid ItemsSource="{Binding MacchineFiltrate}"
                          SelectedItem="{Binding MacchinaSelezionata, Mode=TwoWay}"
                          CanUserAddRows="False" IsReadOnly="True"
                          RowHeight="36">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource DataGridRow.Base}">
                            <EventSetter Event="MouseDoubleClick" Handler="Row_MouseDoubleClick"/>
                            <Setter Property="Cursor" Value="Hand"/>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Codice"
                                           Binding="{Binding CodiceMacchina}"
                                           Width="160"/>
                        <DataGridTextColumn Header="Nome"
                                           Binding="{Binding NomeMacchina}"
                                           Width="*"/>
                        <DataGridTextColumn Header="Formato"
                                           Binding="{Binding Formato.NomeFormato}"
                                           Width="110"/>
                        <DataGridTextColumn Header="Produttore"
                                           Binding="{Binding Produttore.NomeProduttore}"
                                           Width="110"/>
                        <DataGridCheckBoxColumn Header="Att."
                                               Binding="{Binding Attiva}"
                                               Width="45"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Pannello destra: dettaglio OPPURE form -->
            <Grid Grid.Column="2">

                <!-- ── Form creazione/modifica ─────────────────── -->
                <ScrollViewer Visibility="{Binding IsFormVisible, Converter={StaticResource BoolToVis}}"
                              VerticalScrollBarVisibility="Auto">
                <Border Background="{DynamicResource Brush.Surface}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource Radius.M}"
                        Padding="20" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="{Binding FormTitolo}"
                                   Style="{StaticResource TextBlock.Subtitle}"
                                   Margin="0,0,0,16"/>

                        <!-- Avviso duplicato -->
                        <Border Background="{DynamicResource Brush.WarningSurface}"
                                BorderBrush="{DynamicResource Brush.Warning}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource Radius.S}"
                                Padding="10,8" Margin="0,0,0,12"
                                Visibility="{Binding IsAvvisoDuplicatoVisible, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding AvvisoDuplicato}"
                                       TextWrapping="Wrap"
                                       FontSize="{StaticResource FontSize.Caption}"
                                       Foreground="{DynamicResource Brush.Warning}"/>
                        </Border>

                        <TextBlock Text="Codice macchina *" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding FormCodiceMacchina, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FieldBox}"/>

                        <TextBlock Text="Nome macchina *" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding FormNomeMacchina, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FieldBox}"/>

                        <TextBlock Text="Formato" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding FormatiMacchine}"
                                  SelectedItem="{Binding FormFormatoSelezionato}"
                                  DisplayMemberPath="NomeFormato"
                                  Margin="0,0,0,8"/>

                        <TextBlock Text="Produttore" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding ProduttoriMacchine}"
                                  SelectedItem="{Binding FormProduttoreSelezionato}"
                                  DisplayMemberPath="NomeProduttore"
                                  Margin="0,0,0,8"/>

                        <!-- Misure -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Larghezza (mm)" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding FormLarghezza, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FieldBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Altezza (mm)" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding FormAltezza, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FieldBox}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Versione" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding FormVersione, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FieldBox}"/>

                        <TextBlock Text="Note" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding FormNote, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FieldBox}"
                                 AcceptsReturn="True" Height="60"/>

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Salva"
                                    Command="{Binding SalvaCommand}"
                                    Margin="0,0,10,0"/>
                            <Button Content="Annulla"
                                    Command="{Binding AnnullaFormCommand}"
                                    Style="{StaticResource Button.Secondary}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                </ScrollViewer>

                <!-- ── Dettaglio macchina selezionata ──────────── -->
                <ScrollViewer Visibility="{Binding IsDetailVisible, Converter={StaticResource BoolToVis}}"
                              VerticalScrollBarVisibility="Auto">
                    <Border Background="{DynamicResource Brush.Surface}"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource Radius.M}"
                            Padding="20">
                        <StackPanel>
                            <!-- Header dettaglio -->
                            <DockPanel Margin="0,0,0,16">
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                            VerticalAlignment="Top">
                                    <Button Content="Modifica"
                                            Command="{Binding ModificaCommand}"
                                            Style="{StaticResource Button.Secondary}"
                                            Margin="0,0,8,0"/>
                                    <Button Content="{Binding ToggleAttivaLabel}"
                                            Command="{Binding ToggleAttivaCommand}"
                                            Style="{StaticResource Button.Ghost}"/>
                                </StackPanel>
                                <StackPanel VerticalAlignment="Top">
                                    <TextBlock Text="{Binding MacchinaSelezionata.NomeMacchina}"
                                               Style="{StaticResource TextBlock.BodyLarge}"
                                               FontWeight="{StaticResource FontWeight.SemiBold}"/>
                                    <TextBlock Text="{Binding MacchinaSelezionata.CodiceMacchina}"
                                               Style="{StaticResource TextBlock.Caption}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </DockPanel>

                            <!-- Info base -->
                            <Border Margin="0,0,0,16"
                                    Style="{StaticResource Card.Subtle}"
                                    Padding="12,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Formato" Style="{StaticResource TextBlock.Caption}"/>
                                        <TextBlock Text="{Binding MacchinaSelezionata.Formato.NomeFormato, FallbackValue='—'}"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock Text="Larghezza (mm)" Style="{StaticResource TextBlock.Caption}"/>
                                        <TextBlock Text="{Binding MacchinaSelezionata.LarghezzaMm, FallbackValue='—'}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Produttore" Style="{StaticResource TextBlock.Caption}"/>
                                        <TextBlock Text="{Binding MacchinaSelezionata.Produttore.NomeProduttore, FallbackValue='—'}"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock Text="Altezza (mm)" Style="{StaticResource TextBlock.Caption}"/>
                                        <TextBlock Text="{Binding MacchinaSelezionata.AltezzaMm, FallbackValue='—'}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Versione -->
                            <Border Margin="0,0,0,16"
                                    Style="{StaticResource Card.Subtle}"
                                    Padding="12,10">
                                <StackPanel>
                                    <TextBlock Text="Versione" Style="{StaticResource TextBlock.Caption}"/>
                                    <TextBlock Text="{Binding MacchinaSelezionata.Versione, FallbackValue='—'}"/>
                                </StackPanel>
                            </Border>

                            <!-- Piastre compatibili -->
                            <DockPanel Margin="0,0,0,6">
                                <Button DockPanel.Dock="Right"
                                        Content="+ Aggiungi"
                                        Command="{Binding AggiungiPiastraCommand}"
                                        Style="{StaticResource Button.Secondary}"/>
                                <TextBlock Text="Piastre compatibili"
                                           Style="{StaticResource SectionTitle}"
                                           VerticalAlignment="Center" Margin="0"/>
                            </DockPanel>

                            <!-- Inline: aggiungi piastra compatibile -->
                            <Border Visibility="{Binding IsAggiungiPiastraVisible, Converter={StaticResource BoolToVis}}"
                                    Style="{StaticResource Card.Accent}"
                                    Padding="12,10" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="Seleziona piastra:"
                                               FontSize="{StaticResource FontSize.Caption}"
                                               Foreground="{DynamicResource Brush.Primary}"
                                               Margin="0,0,0,6"/>
                                    <ComboBox ItemsSource="{Binding PiastreDisponibili}"
                                              SelectedItem="{Binding PiastraCompatibileDaAggiungere}"
                                              Margin="0,0,0,8">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding CodicePiastra}"
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock Text=" — "/>
                                                    <TextBlock Text="{Binding Descrizione}"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxWidth="160"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Conferma"
                                                Command="{Binding ConfermaAggiungiPiastraCommand}"
                                                Margin="0,0,8,0"/>
                                        <Button Content="Annulla"
                                                Command="{Binding AnnullaAggiungiPiastraCommand}"
                                                Style="{StaticResource Button.Secondary}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- DataGrid piastre compatibili -->
                            <Border BorderBrush="{DynamicResource Brush.Border}"
                                    BorderThickness="1"
                                    Margin="0,0,0,4" MaxHeight="180">
                                <DataGrid ItemsSource="{Binding PiastreCompatibili}"
                                          CanUserAddRows="False" IsReadOnly="True"
                                          RowHeight="30" ColumnHeaderHeight="30">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Codice"
                                                           Binding="{Binding Piastra.CodicePiastra}"
                                                           Width="100"/>
                                        <DataGridTextColumn Header="Descrizione"
                                                           Binding="{Binding Piastra.Descrizione}"
                                                           Width="*"/>
                                        <DataGridTemplateColumn Header="" Width="44">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Style="{StaticResource Button.IconDanger}"
                                                            ToolTip="Rimuovi"
                                                            Command="{Binding DataContext.RimuoviCompatibilitaCommand,
                                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}">
                                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets"
                                                                   Foreground="{DynamicResource Brush.Error}"/>
                                                    </Button>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>

                            <Separator Margin="0,4,0,8"/>

                            <!-- Clienti associati -->
                            <DockPanel Margin="0,0,0,6">
                                <Button DockPanel.Dock="Right"
                                        Content="+ Aggiungi"
                                        Command="{Binding AggiungiClienteCommand}"
                                        Style="{StaticResource Button.Secondary}"/>
                                <TextBlock Text="Clienti che la possiedono"
                                           Style="{StaticResource SectionTitle}"
                                           VerticalAlignment="Center" Margin="0"/>
                            </DockPanel>

                            <!-- Inline: aggiungi cliente associato -->
                            <Border Visibility="{Binding IsAggiungiClienteVisible, Converter={StaticResource BoolToVis}}"
                                    Style="{StaticResource Card.Accent}"
                                    Padding="12,10" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="Seleziona cliente:"
                                               FontSize="{StaticResource FontSize.Caption}"
                                               Foreground="{DynamicResource Brush.Primary}"
                                               Margin="0,0,0,6"/>

                                    <!-- Chip cliente selezionato -->
                                    <Border Visibility="{Binding IsClienteSelezionatoVisible, Converter={StaticResource BoolToVis}}"
                                            Background="{DynamicResource Brush.PrimarySubtle}"
                                            BorderBrush="{DynamicResource Brush.Primary}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource Radius.S}"
                                            Padding="8,5" Margin="0,0,0,8">
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right"
                                                    Style="{StaticResource Button.Icon}"
                                                    Command="{Binding RimuoviClienteSelezionatoCommand}"
                                                    Margin="6,0,0,0">
                                                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                                           FontSize="10" FontWeight="Normal"/>
                                            </Button>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock FontWeight="{StaticResource FontWeight.SemiBold}"
                                                           Text="{Binding ClienteSelezionato.RagioneSociale}"/>
                                                <TextBlock Text="{Binding ClienteSelezionato.CodiceClienteGestionale}"
                                                           FontSize="{StaticResource FontSize.Caption}"
                                                           Foreground="{DynamicResource Brush.TextSecondary}"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>

                                    <!-- Ricerca typeahead -->
                                    <Grid Visibility="{Binding IsClienteSearchVisible, Converter={StaticResource BoolToVis}}"
                                          Margin="0,0,0,8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBox Grid.Row="0"
                                                 Text="{Binding FiltroCliente, UpdateSourceTrigger=PropertyChanged}"/>
                                        <Border Grid.Row="1"
                                                Visibility="{Binding IsClienteSuggerimentiVisible, Converter={StaticResource BoolToVis}}"
                                                Background="{DynamicResource Brush.Surface}"
                                                BorderBrush="{DynamicResource Brush.Border}"
                                                BorderThickness="1"
                                                CornerRadius="{StaticResource Radius.S}"
                                                Margin="0,2,0,0">
                                            <ItemsControl ItemsSource="{Binding ClientiSuggeriti}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Style="{StaticResource Button.Ghost}"
                                                                HorizontalContentAlignment="Left"
                                                                HorizontalAlignment="Stretch"
                                                                Command="{Binding DataContext.SelezionaClienteCommand,
                                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"
                                                                Padding="8,5">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding CodiceClienteGestionale}"
                                                                           FontWeight="{StaticResource FontWeight.SemiBold}"
                                                                           Foreground="{DynamicResource Brush.TextSecondary}"
                                                                           MinWidth="60" Margin="0,0,8,0"/>
                                                                <TextBlock Text="{Binding RagioneSociale}"/>
                                                            </StackPanel>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Border>
                                    </Grid>

                                    <TextBlock Text="Matricola (opzionale):"
                                               FontSize="{StaticResource FontSize.Caption}"
                                               Foreground="{DynamicResource Brush.Primary}"
                                               Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding FormMatricola, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Conferma"
                                                Command="{Binding ConfermaAggiungiClienteCommand}"
                                                Margin="0,0,8,0"/>
                                        <Button Content="Annulla"
                                                Command="{Binding AnnullaAggiungiClienteCommand}"
                                                Style="{StaticResource Button.Secondary}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border BorderBrush="{DynamicResource Brush.Border}"
                                    BorderThickness="1"
                                    MaxHeight="150">
                                <DataGrid ItemsSource="{Binding ClientiAssociati}"
                                          CanUserAddRows="False" IsReadOnly="True"
                                          RowHeight="30" ColumnHeaderHeight="30">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Ragione Sociale"
                                                           Binding="{Binding Cliente.RagioneSociale}"
                                                           Width="*"/>
                                        <DataGridTextColumn Header="Matricola"
                                                           Binding="{Binding Matricola}"
                                                           Width="90"/>
                                        <DataGridTemplateColumn Header="" Width="44">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Style="{StaticResource Button.IconDanger}"
                                                            ToolTip="Rimuovi"
                                                            Command="{Binding DataContext.RimuoviClienteCommand,
                                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}">
                                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets"
                                                                   Foreground="{DynamicResource Brush.Error}"/>
                                                    </Button>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </StackPanel>
                    </Border>
                </ScrollViewer>

            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
