<UserControl x:Class="PlateArchive.Wpf.Views.PiastreView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="#1E2A3B"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="14,7"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#263340"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#BDBDBD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Padding"     Value="12,6"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="BorderBrush" Value="#BDBDBD"/>
            <Setter Property="Background"  Value="White"/>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button">
            <Setter Property="Padding"         Value="8,4"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Background"      Value="#FFEBEE"/>
            <Setter Property="Foreground"      Value="#C62828"/>
            <Setter Property="BorderBrush"     Value="#EF9A9A"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Foreground" Value="#757575"/>
            <Setter Property="Margin"     Value="0,0,0,3"/>
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Padding"     Value="7,5"/>
            <Setter Property="BorderBrush" Value="#BDBDBD"/>
            <Setter Property="Margin"      Value="0,0,0,10"/>
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Foreground" Value="#424242"/>
            <Setter Property="Margin"     Value="0,0,0,6"/>
        </Style>
    </UserControl.Resources>

    <DockPanel Background="#F0F2F5">

        <!-- ── Header ─────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top" Background="White" Padding="24,14"
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="+ Nuova piastra"
                        Command="{Binding NuovaCommand}"
                        Style="{StaticResource PrimaryBtn}"/>

                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Piastre" FontSize="20" FontWeight="SemiBold"
                               Foreground="#212121" Margin="0,0,0,10"/>
                    <DockPanel>
                        <ComboBox DockPanel.Dock="Right"
                                  ItemsSource="{Binding StatiFiltro}"
                                  SelectedItem="{Binding FiltroStatoSelezionato}"
                                  Width="110" Margin="10,0,0,0"
                                  VerticalAlignment="Center"/>
                        <ComboBox DockPanel.Dock="Right"
                                  ItemsSource="{Binding CategorieFiltro}"
                                  SelectedItem="{Binding FiltroCategoriaSelezionato}"
                                  Width="100" Margin="10,0,0,0"
                                  VerticalAlignment="Center"/>
                        <ComboBox DockPanel.Dock="Right"
                                  ItemsSource="{Binding FormatiMacchinaFiltro}"
                                  SelectedItem="{Binding FiltroFormatoSelezionato}"
                                  Width="80" Margin="10,0,0,0"
                                  VerticalAlignment="Center"/>
                        <TextBox Text="{Binding FiltroRicerca, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" BorderBrush="#BDBDBD" FontSize="13"/>
                    </DockPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Body ───────────────────────────────────────────── -->
        <Grid Margin="24,20,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- Lista piastre -->
            <Border Grid.Column="0" Background="White"
                    BorderBrush="#E0E0E0" BorderThickness="1">
                <Grid>
                    <DataGrid x:Name="PiastreDataGrid"
                              ItemsSource="{Binding PiastreFiltrate}"
                              SelectedItem="{Binding PiastraSelezionata, Mode=TwoWay}"
                              AutoGenerateColumns="False" CanUserAddRows="False"
                              IsReadOnly="True" HeadersVisibility="Column"
                              SelectionMode="Single" GridLinesVisibility="Horizontal"
                              Background="White" AlternatingRowBackground="#FAFAFA"
                              BorderThickness="0" RowHeight="34" ColumnHeaderHeight="34"
                              AllowDrop="True"
                              DragOver="DataGrid_DragOver"
                              DragLeave="DataGrid_DragLeave"
                              Drop="DataGrid_Drop">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <EventSetter Event="MouseDoubleClick" Handler="Row_MouseDoubleClick"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Codice"
                                               Binding="{Binding CodicePiastra}"
                                               Width="130"/>
                            <DataGridTextColumn Header="Art. Gestionale"
                                               Binding="{Binding CodiceArticoloGestionale}"
                                               Width="110"/>
                            <DataGridTextColumn Header="Descrizione"
                                               Binding="{Binding Descrizione}"
                                               Width="*"/>
                            <DataGridTextColumn Header="Categoria"
                                               Binding="{Binding Categoria}"
                                               Width="80"/>
                            <DataGridTextColumn Header="Formato"
                                               Binding="{Binding FormatoMacchina}"
                                               Width="65"/>
                            <DataGridTextColumn Header="Stato"
                                               Binding="{Binding Stato}"
                                               Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Overlay drag & drop -->
                    <Border x:Name="DataGridDropOverlay"
                            Visibility="Collapsed" IsHitTestVisible="False"
                            Background="#CC1565C0" BorderBrush="#1565C0" BorderThickness="3">
                        <TextBlock Text="Rilascia il file sulla piastra"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="White" FontSize="14" TextWrapping="Wrap"
                                   Padding="20" FontWeight="SemiBold"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Pannello destra: dettaglio OPPURE form -->
            <Grid Grid.Column="2">

                <!-- ── Form creazione/modifica ─────────────────── -->
                <Border Visibility="{Binding IsFormVisible, Converter={StaticResource BoolToVis}}"
                        Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                        Padding="20" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="{Binding FormTitolo}"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,0,0,16"/>

                        <!-- Errore codice duplicato -->
                        <Border Background="#FFEBEE" BorderBrush="#EF9A9A" BorderThickness="1"
                                Padding="10,8" Margin="0,0,0,12"
                                Visibility="{Binding IsErroreVisible, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding ErroreCodiceDuplicato}"
                                       TextWrapping="Wrap" FontSize="12" Foreground="#C62828"/>
                        </Border>

                        <TextBlock Text="Codice piastra *" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding FormCodicePiastra, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FieldBox}"/>

                        <TextBlock Text="Codice articolo gestionale" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding FormCodiceArticolo, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FieldBox}"/>

                        <TextBlock Text="Descrizione" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding FormDescrizione, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FieldBox}"/>

                        <TextBlock Text="Stato" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding StatiPiastra}"
                                  SelectedItem="{Binding FormStato}"
                                  Margin="0,0,0,10" Padding="7,5"/>

                        <!-- Categoria e Formato macchina -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Categoria" Style="{StaticResource FieldLabel}"/>
                                <ComboBox ItemsSource="{Binding CategorieForm}"
                                          SelectedItem="{Binding FormCategoria}"
                                          Padding="7,5"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Formato macchina" Style="{StaticResource FieldLabel}"/>
                                <ComboBox ItemsSource="{Binding FormatiMacchina}"
                                          SelectedItem="{Binding FormFormatoMacchina}"
                                          Padding="7,5"/>
                            </StackPanel>
                        </Grid>

                        <!-- Misure -->
                        <TextBlock Text="Misure (mm)" Style="{StaticResource FieldLabel}"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Larghezza" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding FormLarghezza, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="7,5" BorderBrush="#BDBDBD"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Lunghezza" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding FormLunghezza, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="7,5" BorderBrush="#BDBDBD"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Spessore" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding FormSpessore, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="7,5" BorderBrush="#BDBDBD"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Note" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding FormNote, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FieldBox}"
                                 AcceptsReturn="True" Height="60"/>

                        <!-- Drop zone disegno nel form -->
                        <TextBlock Text="Disegno" Style="{StaticResource FieldLabel}" Margin="0,4,0,4"/>
                        <Grid AllowDrop="True"
                              DragOver="FormDisegno_DragOver"
                              DragLeave="FormDisegno_DragLeave"
                              Drop="FormDisegno_Drop"
                              Margin="0,0,0,16" MinHeight="56">
                            <Rectangle Stroke="#BDBDBD" StrokeDashArray="5,3"
                                       StrokeThickness="1.5" Fill="#F5F7FA"
                                       RadiusX="3" RadiusY="3"/>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Margin="8">
                                <TextBlock Text="Trascina qui DWG / DXF / PDF"
                                           FontSize="11" Foreground="#9E9E9E"
                                           HorizontalAlignment="Center"
                                           Visibility="{Binding IsDisegnoPendenteAssente,
                                               Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Text="{Binding NomeFilePendente}"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="#1565C0" HorizontalAlignment="Center"
                                           Visibility="{Binding IsDisegnoPendenteVisible,
                                               Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Text="(verrà associato al salvataggio)"
                                           FontSize="10" Foreground="#9E9E9E"
                                           HorizontalAlignment="Center"
                                           Visibility="{Binding IsDisegnoPendenteVisible,
                                               Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>
                            <Border x:Name="FormDisegnoOverlay"
                                    Visibility="Collapsed" IsHitTestVisible="False"
                                    Background="#CC1565C0" BorderBrush="#1565C0" BorderThickness="2">
                                <TextBlock Text="Rilascia per allegare il disegno"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                            <Button Content="Salva"
                                    Command="{Binding SalvaCommand}"
                                    Style="{StaticResource PrimaryBtn}"
                                    Margin="0,0,10,0"/>
                            <Button Content="Annulla"
                                    Command="{Binding AnnullaFormCommand}"
                                    Style="{StaticResource SecondaryBtn}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ── Dettaglio piastra selezionata ──────────── -->
                <ScrollViewer Visibility="{Binding IsDetailVisible, Converter={StaticResource BoolToVis}}"
                              VerticalScrollBarVisibility="Auto">
                    <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                            Padding="20">
                        <StackPanel>
                            <!-- Header dettaglio -->
                            <DockPanel Margin="0,0,0,16">
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="{Binding PiastraSelezionata.CodicePiastra}"
                                               FontSize="15" FontWeight="SemiBold" Foreground="#212121"/>
                                    <TextBlock Text="{Binding PiastraSelezionata.Descrizione}"
                                               FontSize="11" Foreground="#757575" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button DockPanel.Dock="Right"
                                        Content="Modifica"
                                        Command="{Binding ModificaCommand}"
                                        Style="{StaticResource SecondaryBtn}"
                                        VerticalAlignment="Top"/>
                            </DockPanel>

                            <!-- Info base -->
                            <Border Background="#F5F7FA" Padding="12,10" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Stato" FontSize="10" Foreground="#9E9E9E"/>
                                        <TextBlock Text="{Binding PiastraSelezionata.Stato}"
                                                   FontSize="13" Margin="0,0,0,8"/>
                                        <TextBlock Text="Categoria" FontSize="10" Foreground="#9E9E9E"/>
                                        <TextBlock Text="{Binding PiastraSelezionata.Categoria, FallbackValue='—'}"
                                                   FontSize="13" Margin="0,0,0,8"/>
                                        <TextBlock Text="Art. gestionale" FontSize="10" Foreground="#9E9E9E"/>
                                        <TextBlock Text="{Binding PiastraSelezionata.CodiceArticoloGestionale, FallbackValue='—'}"
                                                   FontSize="13"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Formato macchina" FontSize="10" Foreground="#9E9E9E"/>
                                        <TextBlock Text="{Binding PiastraSelezionata.FormatoMacchina, FallbackValue='—'}"
                                                   FontSize="13" Margin="0,0,0,8"/>
                                        <TextBlock Text="Creato il" FontSize="10" Foreground="#9E9E9E"/>
                                        <TextBlock FontSize="13" Margin="0,0,0,8">
                                            <TextBlock.Text>
                                                <Binding Path="PiastraSelezionata.DataCreazione" StringFormat="dd/MM/yyyy"/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <TextBlock Text="Ultima modifica" FontSize="10" Foreground="#9E9E9E"/>
                                        <TextBlock FontSize="13">
                                            <TextBlock.Text>
                                                <Binding Path="PiastraSelezionata.DataUltimaModifica" StringFormat="dd/MM/yyyy"/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Misure -->
                            <Border Background="#F5F7FA" Padding="12,10" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Larghezza" FontSize="10" Foreground="#9E9E9E"/>
                                        <TextBlock FontSize="13">
                                            <TextBlock.Text>
                                                <Binding Path="PiastraSelezionata.LarghezzaMm"
                                                         StringFormat="{}{0:F1} mm"
                                                         FallbackValue="—" TargetNullValue="—"/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Lunghezza" FontSize="10" Foreground="#9E9E9E"/>
                                        <TextBlock FontSize="13">
                                            <TextBlock.Text>
                                                <Binding Path="PiastraSelezionata.LunghezzaMm"
                                                         StringFormat="{}{0:F1} mm"
                                                         FallbackValue="—" TargetNullValue="—"/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Spessore" FontSize="10" Foreground="#9E9E9E"/>
                                        <TextBlock FontSize="13">
                                            <TextBlock.Text>
                                                <Binding Path="PiastraSelezionata.SpessoreMm"
                                                         StringFormat="{}{0:F2} mm"
                                                         FallbackValue="—" TargetNullValue="—"/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Sezione Disegno -->
                            <TextBlock Text="Disegno" Style="{StaticResource SectionTitle}"/>

                            <!-- Drop zone disegno (file DWG/DXF/PDF) -->
                            <Grid Margin="0,0,0,16"
                                  AllowDrop="True"
                                  DragOver="DisegnoSection_DragOver"
                                  DragLeave="DisegnoSection_DragLeave"
                                  Drop="DisegnoSection_Drop">
                                <StackPanel>
                                    <!-- Disegno presente -->
                                    <Border Visibility="{Binding IsDisegnoPresente, Converter={StaticResource BoolToVis}}"
                                            Background="#F5F7FA" Padding="12,10">
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right"
                                                    Content="Apri file"
                                                    Command="{Binding AprirDisegnoCommand}"
                                                    Style="{StaticResource SecondaryBtn}"
                                                    VerticalAlignment="Center"
                                                    Margin="8,0,0,0"/>
                                            <StackPanel DockPanel.Dock="Left">
                                                <TextBlock Text="{Binding PiastraSelezionata.Disegno.CodiceDisegno}"
                                                           FontSize="13" FontWeight="SemiBold"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock Text="Rev. " FontSize="11" Foreground="#757575"/>
                                                    <TextBlock Text="{Binding PiastraSelezionata.Disegno.Revisione, FallbackValue='—'}"
                                                               FontSize="11" Foreground="#757575"/>
                                                    <TextBlock Text=" · " FontSize="11" Foreground="#757575"/>
                                                    <TextBlock Text="{Binding PiastraSelezionata.Disegno.Stato}"
                                                               FontSize="11" Foreground="#757575"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding PiastraSelezionata.Disegno.PercorsoFile}"
                                                           FontSize="10" Foreground="#9E9E9E" Margin="0,2,0,0"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>

                                    <!-- Disegno assente -->
                                    <Border Visibility="{Binding IsDisegnoAssente, Converter={StaticResource BoolToVis}}"
                                            Background="#F5F7FA" Padding="12,10" MinHeight="44">
                                        <TextBlock Text="Nessun disegno associato. Trascina qui un file DWG/DXF/PDF."
                                                   FontSize="12" Foreground="#9E9E9E"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>

                                <!-- Overlay drag attivo -->
                                <Border x:Name="DisegnoSectionOverlay"
                                        Visibility="Collapsed" IsHitTestVisible="False"
                                        Background="#CC1565C0" BorderBrush="#1565C0" BorderThickness="2">
                                    <TextBlock Text="Rilascia per associare il disegno"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                </Border>
                            </Grid>

                            <!-- Errore apertura file disegno -->
                            <Border Background="#FFEBEE" BorderBrush="#EF9A9A" BorderThickness="1"
                                    Padding="10,8" Margin="0,0,0,12"
                                    Visibility="{Binding IsErroreDisegnoVisible, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding ErroreDisegno}"
                                           TextWrapping="Wrap" FontSize="11" Foreground="#C62828"/>
                            </Border>

                            <!-- Sezione Macchine compatibili -->
                            <DockPanel Margin="0,0,0,6">
                                <Button DockPanel.Dock="Right"
                                        Content="+ Aggiungi"
                                        Command="{Binding AggiungiMacchinaCommand}"
                                        Style="{StaticResource SecondaryBtn}"
                                        FontSize="11" Padding="8,4"/>
                                <TextBlock Text="Macchine compatibili" Style="{StaticResource SectionTitle}"
                                           VerticalAlignment="Center" Margin="0"/>
                            </DockPanel>

                            <!-- Inline: aggiungi macchina compatibile -->
                            <Border Visibility="{Binding IsAggiungiMacchinaVisible, Converter={StaticResource BoolToVis}}"
                                    Background="#E3F2FD" BorderBrush="#90CAF9" BorderThickness="1"
                                    Padding="12,10" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="Seleziona macchina:" FontSize="11" Foreground="#1565C0"
                                               Margin="0,0,0,6"/>
                                    <ComboBox ItemsSource="{Binding MacchineDisponibili}"
                                              SelectedItem="{Binding MacchinaCompatibileDaAggiungere}"
                                              DisplayMemberPath="NomeMacchina"
                                              Margin="0,0,0,8" Padding="7,5"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Conferma"
                                                Command="{Binding ConfermaAggiungiMacchinaCommand}"
                                                Style="{StaticResource PrimaryBtn}"
                                                FontSize="11" Padding="10,5"
                                                Margin="0,0,8,0"/>
                                        <Button Content="Annulla"
                                                Command="{Binding AnnullaAggiungiMacchinaCommand}"
                                                Style="{StaticResource SecondaryBtn}"
                                                FontSize="11" Padding="10,5"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- DataGrid macchine compatibili -->
                            <Border BorderBrush="#E0E0E0" BorderThickness="1"
                                    Margin="0,0,0,16" MaxHeight="180">
                                <DataGrid ItemsSource="{Binding MacchineCompatibili}"
                                          AutoGenerateColumns="False" CanUserAddRows="False"
                                          IsReadOnly="True" HeadersVisibility="Column"
                                          Background="White" BorderThickness="0"
                                          RowHeight="28" ColumnHeaderHeight="28">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Macchina"
                                                           Binding="{Binding MacchinaStandard.NomeMacchina}"
                                                           Width="*"/>
                                        <DataGridTextColumn Header="Codice"
                                                           Binding="{Binding MacchinaStandard.CodiceMacchina}"
                                                           Width="110"/>
                                        <DataGridTemplateColumn Header="" Width="60">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="Rimuovi"
                                                            FontSize="10" Padding="6,3"
                                                            Style="{StaticResource DangerBtn}"
                                                            Command="{Binding DataContext.RimuoviCompatibilitaCommand,
                                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Cursor="Hand"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>

                            <!-- Sezione Clienti associati -->
                            <TextBlock Text="Clienti associati" Style="{StaticResource SectionTitle}"/>
                            <Border BorderBrush="#E0E0E0" BorderThickness="1" MaxHeight="160">
                                <DataGrid ItemsSource="{Binding ClientiAssociati}"
                                          AutoGenerateColumns="False" CanUserAddRows="False"
                                          IsReadOnly="True" HeadersVisibility="Column"
                                          Background="White" BorderThickness="0"
                                          RowHeight="28" ColumnHeaderHeight="28">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Cliente"
                                                           Binding="{Binding Cliente.RagioneSociale}"
                                                           Width="*"/>
                                        <DataGridTextColumn Header="Macchina"
                                                           Binding="{Binding ClienteMacchina.MacchinaStandard.NomeMacchina}"
                                                           Width="120"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>

                        </StackPanel>
                    </Border>
                </ScrollViewer>

            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
