<UserControl x:Class="PlateArchive.Wpf.Views.PiastreView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
    PiastreView — schermata catalogo piastre.
    Layout: DockPanel verticale (Header + filtri | Grid orizzontale lista | pannello destra)

    Pannello destra mostra (Visibility alternata):
      - Form creazione/modifica (IsFormVisible = true)
      - Dettaglio piastra: macchine compatibili + clienti associati (IsDetailVisible = true)

    Funzionalità:
      - Drag-drop file su riga DataGrid → chiama PiastreView.xaml.cs → AssociaDisegnoAsync
      - Filtro per testo, stato, categoria, formato (tutti in memoria, senza query al DB)
    -->

    <DockPanel Background="{DynamicResource Brush.Background}">

        <!-- ── Header ─────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource Brush.Surface}"
                Padding="24,14"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="0,0,0,1">
            <StackPanel>
                <!-- Riga 1: titolo + pulsante -->
                <DockPanel Margin="0,0,0,10">
                    <Button DockPanel.Dock="Right"
                            Content="+ Nuova piastra"
                            Command="{Binding NuovaCommand}"
                            Margin="12,0,0,0"/>
                    <TextBlock Text="Piastre"
                               Style="{StaticResource TextBlock.Title}"
                               VerticalAlignment="Center"/>
                </DockPanel>
                <!-- Riga 2: filtri -->
                <DockPanel>
                    <ComboBox DockPanel.Dock="Right"
                              ItemsSource="{Binding StatiFiltro}"
                              SelectedItem="{Binding FiltroStatoSelezionato}"
                              Width="110" Margin="10,0,0,0"
                              VerticalAlignment="Center"/>
                    <ComboBox DockPanel.Dock="Right"
                              ItemsSource="{Binding FormatiFiltro}"
                              SelectedItem="{Binding FiltroFormatoSelezionato}"
                              Width="80" Margin="10,0,0,0"
                              VerticalAlignment="Center"/>
                    <ComboBox DockPanel.Dock="Right"
                              ItemsSource="{Binding CategorieFiltro}"
                              SelectedItem="{Binding FiltroCategoriaSelezionato}"
                              Width="110" Margin="10,0,0,0"
                              VerticalAlignment="Center"/>
                    <TextBox Text="{Binding FiltroRicerca, UpdateSourceTrigger=PropertyChanged}"
                             MinWidth="80"/>
                </DockPanel>
            </StackPanel>
        </Border>

        <!-- ── Body ───────────────────────────────────────────── -->
        <Grid Margin="24,20,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- Lista piastre -->
            <Border Grid.Column="0"
                    Background="{DynamicResource Brush.Surface}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1">
                <Grid>
                    <DataGrid x:Name="PiastreDataGrid"
                              ItemsSource="{Binding PiastreFiltrate}"
                              SelectedItem="{Binding PiastraSelezionata, Mode=TwoWay}"
                              CanUserAddRows="False" IsReadOnly="True"
                              RowHeight="36"
                              AllowDrop="True"
                              DragOver="DataGrid_DragOver"
                              DragLeave="DataGrid_DragLeave"
                              Drop="DataGrid_Drop">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow" BasedOn="{StaticResource DataGridRow.Base}">
                                <EventSetter Event="MouseDoubleClick" Handler="Row_MouseDoubleClick"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Codice"
                                               Binding="{Binding CodicePiastra}"
                                               Width="130"/>
                            <DataGridTextColumn Header="Descrizione"
                                               Binding="{Binding Descrizione}"
                                               Width="*"/>
                            <DataGridTextColumn Header="Categoria"
                                               Binding="{Binding Categoria.Descrizione}"
                                               Width="95"/>
                            <DataGridTextColumn Header="Formato"
                                               Binding="{Binding Formato.NomeFormato}"
                                               Width="80"/>
                            <DataGridTextColumn Header="Stato"
                                               Binding="{Binding Stato}"
                                               Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Overlay drag & drop -->
                    <Border x:Name="DataGridDropOverlay"
                            Visibility="Collapsed" IsHitTestVisible="False"
                            Background="{DynamicResource Brush.Overlay}"
                            BorderBrush="{DynamicResource Brush.Primary}"
                            BorderThickness="3">
                        <TextBlock Text="Rilascia il file sulla piastra"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.OnPrimary}"
                                   FontSize="{StaticResource FontSize.BodyLarge}"
                                   TextWrapping="Wrap"
                                   Padding="20"
                                   FontWeight="{StaticResource FontWeight.SemiBold}"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Pannello destra: dettaglio OPPURE form -->
            <Grid Grid.Column="2">

                <!-- ── Form creazione/modifica ─────────────────── -->
                <Border Visibility="{Binding IsFormVisible, Converter={StaticResource BoolToVis}}"
                        Background="{DynamicResource Brush.Surface}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource Radius.M}"
                        Padding="20" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="{Binding FormTitolo}"
                                   Style="{StaticResource TextBlock.Subtitle}"
                                   Margin="0,0,0,16"/>

                        <!-- Errore codice duplicato -->
                        <Border Background="{DynamicResource Brush.ErrorSurface}"
                                BorderBrush="{DynamicResource Brush.Error}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource Radius.S}"
                                Padding="10,8" Margin="0,0,0,12"
                                Visibility="{Binding IsErroreVisible, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding ErroreCodiceDuplicato}"
                                       TextWrapping="Wrap"
                                       FontSize="{StaticResource FontSize.Caption}"
                                       Foreground="{DynamicResource Brush.Error}"/>
                        </Border>

                        <TextBlock Text="Codice piastra *" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding FormCodicePiastra, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FieldBox}"/>

                        <TextBlock Text="Codice articolo gestionale" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding FormCodiceArticolo, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FieldBox}"/>

                        <TextBlock Text="Descrizione" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding FormDescrizione, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FieldBox}"/>

                        <TextBlock Text="Stato" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding StatiPiastra}"
                                  SelectedItem="{Binding FormStato}"
                                  Margin="0,0,0,10"/>

                        <TextBlock Text="Formato macchina" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding FormatiMacchine}"
                                  SelectedItem="{Binding FormFormatoSelezionato}"
                                  DisplayMemberPath="NomeFormato"
                                  Margin="0,0,0,10"/>

                        <!-- Categoria e Peso -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Categoria" Style="{StaticResource FieldLabel}"/>
                                <ComboBox ItemsSource="{Binding CategoriePiastre}"
                                          SelectedItem="{Binding FormCategoriaSelezionata}"
                                          DisplayMemberPath="Descrizione"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Peso (kg)" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding FormPeso, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Misure -->
                        <TextBlock Text="Misure (mm)" Style="{StaticResource FieldLabel}"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Larghezza" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding FormLarghezza, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Altezza" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding FormAltezza, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Spessore" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding FormSpessore, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="6">
                                <TextBlock Text="Durezza" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding FormDurezza, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Note" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding FormNote, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FieldBox}"
                                 AcceptsReturn="True" Height="60"/>

                        <!-- Drop zone disegno nel form -->
                        <TextBlock Text="Disegno" Style="{StaticResource FieldLabel}" Margin="0,4,0,4"/>
                        <Grid AllowDrop="True"
                              DragOver="FormDisegno_DragOver"
                              DragLeave="FormDisegno_DragLeave"
                              Drop="FormDisegno_Drop"
                              Margin="0,0,0,16" MinHeight="56">
                            <Border Background="{DynamicResource Brush.SurfaceAlt}"
                                    BorderBrush="{DynamicResource Brush.Border}"
                                    BorderThickness="1.5"
                                    CornerRadius="{StaticResource Radius.S}">
                            </Border>
                            <Rectangle Stroke="{DynamicResource Brush.Border}"
                                       StrokeDashArray="5,3"
                                       StrokeThickness="1.5"
                                       Fill="{DynamicResource Brush.SurfaceAlt}"
                                       RadiusX="4" RadiusY="4"/>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Margin="8">
                                <TextBlock Text="Trascina qui DWG / DXF / PDF"
                                           FontSize="{StaticResource FontSize.Caption}"
                                           Foreground="{DynamicResource Brush.TextDisabled}"
                                           HorizontalAlignment="Center"
                                           Visibility="{Binding IsDisegnoPendenteAssente,
                                               Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Text="{Binding NomeFilePendente}"
                                           FontSize="{StaticResource FontSize.Body}"
                                           FontWeight="{StaticResource FontWeight.SemiBold}"
                                           Foreground="{DynamicResource Brush.Primary}"
                                           HorizontalAlignment="Center"
                                           Visibility="{Binding IsDisegnoPendenteVisible,
                                               Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Text="(verrà associato al salvataggio)"
                                           FontSize="{StaticResource FontSize.Caption}"
                                           Foreground="{DynamicResource Brush.TextDisabled}"
                                           HorizontalAlignment="Center"
                                           Visibility="{Binding IsDisegnoPendenteVisible,
                                               Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>
                            <Border x:Name="FormDisegnoOverlay"
                                    Visibility="Collapsed" IsHitTestVisible="False"
                                    Background="{DynamicResource Brush.Overlay}"
                                    BorderBrush="{DynamicResource Brush.Primary}"
                                    BorderThickness="2"
                                    CornerRadius="{StaticResource Radius.S}">
                                <TextBlock Text="Rilascia per allegare il disegno"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.OnPrimary}"
                                           FontSize="{StaticResource FontSize.Body}"
                                           FontWeight="{StaticResource FontWeight.SemiBold}"/>
                            </Border>
                        </Grid>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Salva"
                                    Command="{Binding SalvaCommand}"
                                    Margin="0,0,10,0"/>
                            <Button Content="Annulla"
                                    Command="{Binding AnnullaFormCommand}"
                                    Style="{StaticResource Button.Secondary}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ── Dettaglio piastra selezionata ──────────── -->
                <ScrollViewer Visibility="{Binding IsDetailVisible, Converter={StaticResource BoolToVis}}"
                              VerticalScrollBarVisibility="Auto">
                    <Border Background="{DynamicResource Brush.Surface}"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource Radius.M}"
                            Padding="20">
                        <StackPanel>
                            <!-- Header dettaglio -->
                            <DockPanel Margin="0,0,0,16">
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="{Binding PiastraSelezionata.CodicePiastra}"
                                               Style="{StaticResource TextBlock.BodyLarge}"
                                               FontWeight="{StaticResource FontWeight.SemiBold}"/>
                                    <TextBlock Text="{Binding PiastraSelezionata.Descrizione}"
                                               Style="{StaticResource TextBlock.Caption}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button DockPanel.Dock="Right"
                                        Content="Modifica"
                                        Command="{Binding ModificaCommand}"
                                        Style="{StaticResource Button.Secondary}"
                                        VerticalAlignment="Top"/>
                            </DockPanel>

                            <!-- Info base -->
                            <Border Style="{StaticResource Card.Subtle}" Padding="12,10" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Stato" Style="{StaticResource TextBlock.Caption}"/>
                                        <TextBlock Text="{Binding PiastraSelezionata.Stato}" Margin="0,0,0,8"/>
                                        <TextBlock Text="Formato" Style="{StaticResource TextBlock.Caption}"/>
                                        <TextBlock Text="{Binding PiastraSelezionata.Formato.NomeFormato, FallbackValue='—'}" Margin="0,0,0,8"/>
                                        <TextBlock Text="Categoria" Style="{StaticResource TextBlock.Caption}"/>
                                        <TextBlock Text="{Binding PiastraSelezionata.Categoria.Descrizione, FallbackValue='—'}" Margin="0,0,0,8"/>
                                        <TextBlock Text="Art. gestionale" Style="{StaticResource TextBlock.Caption}"/>
                                        <TextBlock Text="{Binding PiastraSelezionata.CodiceArticoloGestionale, FallbackValue='—'}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Peso (kg)" Style="{StaticResource TextBlock.Caption}"/>
                                        <TextBlock Text="{Binding PiastraSelezionata.Peso, StringFormat='{}{0:F3}', FallbackValue='—', TargetNullValue='—'}" Margin="0,0,0,8"/>
                                        <TextBlock Text="Creato il" Style="{StaticResource TextBlock.Caption}"/>
                                        <TextBlock Margin="0,0,0,8">
                                            <TextBlock.Text>
                                                <Binding Path="PiastraSelezionata.DataCreazione" StringFormat="dd/MM/yyyy"/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <TextBlock Text="Ultima modifica" Style="{StaticResource TextBlock.Caption}"/>
                                        <TextBlock>
                                            <TextBlock.Text>
                                                <Binding Path="PiastraSelezionata.DataUltimaModifica" StringFormat="dd/MM/yyyy"/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Misure -->
                            <Border Style="{StaticResource Card.Subtle}" Padding="12,10" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Larghezza" Style="{StaticResource TextBlock.Caption}"/>
                                        <TextBlock>
                                            <TextBlock.Text>
                                                <Binding Path="PiastraSelezionata.LarghezzaMm"
                                                         StringFormat="{}{0:F1} mm"
                                                         FallbackValue="—" TargetNullValue="—"/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Altezza" Style="{StaticResource TextBlock.Caption}"/>
                                        <TextBlock>
                                            <TextBlock.Text>
                                                <Binding Path="PiastraSelezionata.AltezzaMm"
                                                         StringFormat="{}{0:F1} mm"
                                                         FallbackValue="—" TargetNullValue="—"/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Spessore" Style="{StaticResource TextBlock.Caption}"/>
                                        <TextBlock>
                                            <TextBlock.Text>
                                                <Binding Path="PiastraSelezionata.SpessoreMm"
                                                         StringFormat="{}{0:F2} mm"
                                                         FallbackValue="—" TargetNullValue="—"/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3">
                                        <TextBlock Text="Durezza" Style="{StaticResource TextBlock.Caption}"/>
                                        <TextBlock>
                                            <TextBlock.Text>
                                                <Binding Path="PiastraSelezionata.Durezza"
                                                         StringFormat="{}{0:F1}"
                                                         FallbackValue="—" TargetNullValue="—"/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Sezione Disegno -->
                            <TextBlock Text="Disegno" Style="{StaticResource SectionTitle}"/>

                            <!-- Drop zone disegno -->
                            <Grid Margin="0,0,0,16"
                                  AllowDrop="True"
                                  DragOver="DisegnoSection_DragOver"
                                  DragLeave="DisegnoSection_DragLeave"
                                  Drop="DisegnoSection_Drop">
                                <StackPanel>
                                    <!-- Disegno presente -->
                                    <Border Visibility="{Binding IsDisegnoPresente, Converter={StaticResource BoolToVis}}"
                                            Style="{StaticResource Card.Subtle}"
                                            Padding="12,10">
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right"
                                                    Content="Apri file"
                                                    Command="{Binding AprirDisegnoCommand}"
                                                    Style="{StaticResource Button.Secondary}"
                                                    VerticalAlignment="Center"
                                                    Margin="8,0,0,0"/>
                                            <StackPanel DockPanel.Dock="Left">
                                                <TextBlock Text="{Binding PiastraSelezionata.Disegno.CodiceDisegno}"
                                                           FontWeight="{StaticResource FontWeight.SemiBold}"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock Text="Rev. " Style="{StaticResource TextBlock.Caption}"/>
                                                    <TextBlock Text="{Binding PiastraSelezionata.Disegno.Revisione, FallbackValue='—'}"
                                                               Style="{StaticResource TextBlock.Caption}"/>
                                                    <TextBlock Text=" · " Style="{StaticResource TextBlock.Caption}"/>
                                                    <TextBlock Text="{Binding PiastraSelezionata.Disegno.Stato}"
                                                               Style="{StaticResource TextBlock.Caption}"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding PiastraSelezionata.Disegno.PercorsoFile}"
                                                           Style="{StaticResource TextBlock.Caption}"
                                                           Margin="0,2,0,0"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>

                                    <!-- Disegno assente -->
                                    <Border Visibility="{Binding IsDisegnoAssente, Converter={StaticResource BoolToVis}}"
                                            Style="{StaticResource Card.Subtle}"
                                            Padding="12,10" MinHeight="44">
                                        <TextBlock Text="Nessun disegno associato. Trascina qui un file DWG/DXF/PDF."
                                                   Foreground="{DynamicResource Brush.TextDisabled}"
                                                   FontSize="{StaticResource FontSize.Caption}"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>

                                <!-- Overlay drag attivo -->
                                <Border x:Name="DisegnoSectionOverlay"
                                        Visibility="Collapsed" IsHitTestVisible="False"
                                        Background="{DynamicResource Brush.Overlay}"
                                        BorderBrush="{DynamicResource Brush.Primary}"
                                        BorderThickness="2"
                                        CornerRadius="{StaticResource Radius.S}">
                                    <TextBlock Text="Rilascia per associare il disegno"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="{DynamicResource Brush.OnPrimary}"
                                               FontSize="{StaticResource FontSize.Body}"
                                               FontWeight="{StaticResource FontWeight.SemiBold}"/>
                                </Border>
                            </Grid>

                            <!-- Errore apertura file disegno -->
                            <Border Background="{DynamicResource Brush.ErrorSurface}"
                                    BorderBrush="{DynamicResource Brush.Error}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource Radius.S}"
                                    Padding="10,8" Margin="0,0,0,12"
                                    Visibility="{Binding IsErroreDisegnoVisible, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding ErroreDisegno}"
                                           TextWrapping="Wrap"
                                           FontSize="{StaticResource FontSize.Caption}"
                                           Foreground="{DynamicResource Brush.Error}"/>
                            </Border>

                            <!-- Sezione Macchine compatibili -->
                            <DockPanel Margin="0,0,0,6">
                                <Button DockPanel.Dock="Right"
                                        Content="+ Aggiungi"
                                        Command="{Binding AggiungiMacchinaCommand}"
                                        Style="{StaticResource Button.Ghost}"
                                        Padding="8,4"/>
                                <TextBlock Text="Macchine compatibili"
                                           Style="{StaticResource SectionTitle}"
                                           VerticalAlignment="Center" Margin="0"/>
                            </DockPanel>

                            <!-- Inline: aggiungi macchina compatibile -->
                            <Border Visibility="{Binding IsAggiungiMacchinaVisible, Converter={StaticResource BoolToVis}}"
                                    Style="{StaticResource Card.Accent}"
                                    Padding="12,10" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="Seleziona macchina:"
                                               FontSize="{StaticResource FontSize.Caption}"
                                               Foreground="{DynamicResource Brush.Primary}"
                                               Margin="0,0,0,6"/>
                                    <ComboBox ItemsSource="{Binding MacchineDisponibili}"
                                              SelectedItem="{Binding MacchinaCompatibileDaAggiungere}"
                                              DisplayMemberPath="NomeMacchina"
                                              Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Conferma"
                                                Command="{Binding ConfermaAggiungiMacchinaCommand}"
                                                Margin="0,0,8,0"/>
                                        <Button Content="Annulla"
                                                Command="{Binding AnnullaAggiungiMacchinaCommand}"
                                                Style="{StaticResource Button.Secondary}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- DataGrid macchine compatibili -->
                            <Border BorderBrush="{DynamicResource Brush.Border}"
                                    BorderThickness="1"
                                    Margin="0,0,0,16" MaxHeight="180">
                                <DataGrid ItemsSource="{Binding MacchineCompatibili}"
                                          CanUserAddRows="False" IsReadOnly="True"
                                          RowHeight="30" ColumnHeaderHeight="30">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Macchina"
                                                           Binding="{Binding MacchinaStandard.NomeMacchina}"
                                                           Width="*"/>
                                        <DataGridTextColumn Header="Codice"
                                                           Binding="{Binding MacchinaStandard.CodiceMacchina}"
                                                           Width="110"/>
                                        <DataGridTemplateColumn Header="" Width="60">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="Rimuovi"
                                                            Padding="6,3"
                                                            Style="{StaticResource DangerBtn}"
                                                            Command="{Binding DataContext.RimuoviCompatibilitaCommand,
                                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>

                            <!-- Sezione Clienti associati -->
                            <TextBlock Text="Clienti associati" Style="{StaticResource SectionTitle}"/>
                            <Border BorderBrush="{DynamicResource Brush.Border}"
                                    BorderThickness="1" MaxHeight="160">
                                <DataGrid ItemsSource="{Binding ClientiAssociati}"
                                          CanUserAddRows="False" IsReadOnly="True"
                                          RowHeight="30" ColumnHeaderHeight="30">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Cliente"
                                                           Binding="{Binding Cliente.RagioneSociale}"
                                                           Width="*"/>
                                        <DataGridTextColumn Header="Macchina"
                                                           Binding="{Binding ClienteMacchina.MacchinaStandard.NomeMacchina}"
                                                           Width="120"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>

                        </StackPanel>
                    </Border>
                </ScrollViewer>

            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
