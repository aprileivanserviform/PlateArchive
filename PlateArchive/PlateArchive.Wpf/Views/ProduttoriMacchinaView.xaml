<UserControl x:Class="PlateArchive.Wpf.Views.ProduttoriMacchinaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
    ProduttoriMacchinaView — gestione CRUD dei produttori di macchine (sezione Impostazioni).
    Layout: Header | Grid orizzontale:
      - Sinistra: DataGrid lista produttori + pulsante "Nuovo produttore"
      - Destra: pannello azioni (IsDetailVisible) OPPURE form (IsFormVisible)
    -->

    <DockPanel Background="{DynamicResource Brush.Background}">

        <!-- ── Header ─────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource Brush.Surface}"
                Padding="24,14"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="+ Nuovo produttore"
                        Command="{Binding NuovoCommand}"/>
                <TextBlock Text="Produttori Macchina"
                           Style="{StaticResource TextBlock.Title}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- ── Body ───────────────────────────────────────────── -->
        <Grid Margin="24,20,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Lista produttori -->
            <Border Grid.Column="0"
                    Background="{DynamicResource Brush.Surface}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1">
                <DataGrid ItemsSource="{Binding Produttori}"
                          SelectedItem="{Binding ProduttoreSelezionato, Mode=TwoWay}"
                          CanUserAddRows="False" IsReadOnly="True"
                          RowHeight="36">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource DataGridRow.Base}">
                            <Setter Property="Cursor" Value="Hand"/>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Produttore"
                                           Binding="{Binding NomeProduttore}"
                                           Width="180"/>
                        <DataGridTextColumn Header="Note"
                                           Binding="{Binding Note}"
                                           Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Pannello destra -->
            <Grid Grid.Column="2">

                <!-- Azioni su produttore selezionato -->
                <Border Visibility="{Binding IsDetailVisible, Converter={StaticResource BoolToVis}}"
                        Background="{DynamicResource Brush.Surface}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource Radius.M}"
                        Padding="20" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="{Binding ProduttoreSelezionato.NomeProduttore}"
                                   Style="{StaticResource TextBlock.Subtitle}"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding ProduttoreSelezionato.Note}"
                                   Style="{StaticResource TextBlock.Caption}"
                                   Margin="0,0,0,20"
                                   TextWrapping="Wrap"/>
                        <Button Content="Modifica"
                                Command="{Binding ModificaCommand}"
                                Style="{StaticResource Button.Secondary}"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,8"/>
                        <Button Content="Elimina"
                                Command="{Binding EliminaCommand}"
                                Style="{StaticResource DangerBtn}"
                                HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>

                <!-- Form creazione/modifica -->
                <Border Visibility="{Binding IsFormVisible, Converter={StaticResource BoolToVis}}"
                        Background="{DynamicResource Brush.Surface}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource Radius.M}"
                        Padding="20" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="{Binding FormTitolo}"
                                   Style="{StaticResource TextBlock.Subtitle}"
                                   Margin="0,0,0,16"/>

                        <!-- Errore duplicato -->
                        <Border Background="{DynamicResource Brush.ErrorSurface}"
                                BorderBrush="{DynamicResource Brush.Error}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource Radius.S}"
                                Padding="10,8" Margin="0,0,0,12"
                                Visibility="{Binding IsErroreVisible, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding Errore}"
                                       TextWrapping="Wrap"
                                       FontSize="{StaticResource FontSize.Caption}"
                                       Foreground="{DynamicResource Brush.Error}"/>
                        </Border>

                        <TextBlock Text="Nome produttore *" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding FormNome, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FieldBox}"/>

                        <TextBlock Text="Note" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding FormNote, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FieldBox}"
                                 AcceptsReturn="True" Height="60"/>

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Salva"
                                    Command="{Binding SalvaCommand}"
                                    Margin="0,0,10,0"/>
                            <Button Content="Annulla"
                                    Command="{Binding AnnullaCommand}"
                                    Style="{StaticResource Button.Secondary}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
